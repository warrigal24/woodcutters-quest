!Replaced actions
Replace _UpdateDarkness;
Replace ImplicitGrabIfNotHeld;
Replace DrinkSub;
Replace LockSub;
Replace UnlockSub;

Include "globals.h";

!Game-specific variables

!========================================
! Entry point routines
!========================================
[ ChooseObjects obj code;
  if (code == 2)
  {
    ! Stage 1: Disambiguation
    if (action_to_be == ##Close)
    {
      if (obj hasnt openable)
        return 0; !Inappropriate
      if (obj has open)
        return 1; !Appropriate
    }
    if (action_to_be == ##Drop && obj in player && obj hasnt worn)
      return 1; !Appropriate
    if (action_to_be == ##Lock)
    {
      if (obj hasnt lockable)
        return 0; !Inappropriate
      if (obj hasnt locked)
        return 1; !Appropriate
    }
    if (action_to_be == ##Open)
    {
      if (obj hasnt openable)
        return 0; !Inappropriate
      if (obj hasnt open)
        return 1; !Appropriate
    }
    if (action_to_be == ##Take && obj notin player)
      return 1; !Appropriate
    if (action_to_be == ##Unlock)
    {
      if (obj hasnt lockable)
        return 0; !Inappropriate
      if (obj has locked)
        return 1; !Appropriate
    }
    return 0; !Inappropriate
  }
  ! Stage 2: Processing an "all"
  if (obj has scenery or concealed or static or animate)
    return 2; !Force exclusion
  if (action_to_be == ##Take && obj ~= player && obj notin player)
    return 1; !Force inclusion
  if (action_to_be == ##Drop && obj in player && obj hasnt worn)
    return 1; !Force inclusion
  return 0; !Accept parser's decision
];

[ LibraryMessages p_msg p_arg_1 p_arg_2;
  switch (p_msg)
  {
    MSG_CLOSE_NOT_OPEN:
      print_ret (CTheyreOrIts)noun, " already closed.";
    MSG_LOCK_ALREADY_LOCKED:
      print_ret (CTheyreOrIts)noun, " already locked.";
    MSG_LOCK_CLOSE_FIRST:
      "You'll have to close ", (ItOrThem)noun, " first.";
    MSG_LOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoOrDoes)second, "n't fit the lock.";
    MSG_UNLOCK_ALREADY_UNLOCKED:
      print_ret (CTheyreOrIts)noun, " already unlocked.";
    MSG_UNLOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoOrDoes)second, "n't fit the lock.";
  }
  p_arg_1 = p_arg_2;
];

Include "puny.h";

!========================================
! Initialisation
!========================================
[ Initialise;
  location = room01;
  lookmode = 2;
  move axe to player;
  no_implicit_actions = true;
  player.description = PlayerDescription;
  "^Your name is John. You're a simple woodcutter from the small village of Cessnock. The weather is usually bright and sunny, and your fellow villagers are usually happy with their lot. Until recently, that is, when rumours started circulating that an evil wizard had taken over the derelict castle across the valley to the east.^^The village elder tried to calm any fears that their simple existence was in peril and, so far, the village has been ignored by the wizard.^^Today, you were out chopping wood in the forest when you heard distant screams. At first, you thought nothing of it, then you saw plumes of smoke rising from the village. You feared the worst. You need to head back to the village to see what's happened.^";
];

!========================================
! Classes
!========================================
!----------------------------------------
! OpenableContainer
!----------------------------------------
Class OpenableContainer
with
  invent
  [;
    if (inventory_stage == 2 && (self hasnt open || child(self) == 0))
      rtrue;
  ],
has container openable;

!----------------------------------------
! OpenContainer
!----------------------------------------
Class OpenContainer
with
  invent
  [;
    if (inventory_stage == 2 && child(self) == 0)
      rtrue;
  ],
has container open;

!----------------------------------------
! Surface
!----------------------------------------
Class Surface
with
  invent
  [;
    if (inventory_stage == 2 && child(self) == 0)
      rtrue;
  ],
has supporter;

!========================================
! Inventory
!========================================
!----------------------------------------
! Axe
!----------------------------------------
Object axe "axe"
with
  article AN,
  name 'woodcutting' 'axe' 'ax' 'trusty',
  description "This is your trusty woodcutting axe.",
  before
  [;
    Sharpen:
      if (second == nothing && rocks in location)
      {
        print "(on the rocks)^";
        second = rocks;
      }
      if (second == nothing)
        print_ret(string)CANT_SEE_ANYTHING_HERE_TO_SHARPEN, (the)self, ".";
      if (second ~= rocks)
        print_ret (string)YOU_CANT_SHARPEN, "axe on ", (ThatOrThose)second, ". You need a grinding stone, or maybe some rocks.";
      "If you have an axe to grind, take it out on the wizard.";
  ],
has;

!========================================
! Room 1: Deep Forest
!========================================
Object room01 "Deep Forest"
with
  description "You're on the fringe of the deep forest where you do most of your woodcutting. The forest is normally full of life, but it's now eerily silent.  The faint smell of smoke may have something to do with that. The way back to the village is to the south.",
  s_to room02,
  before
  [;
    Hint:
      if (logs in nothing)
        print_ret (string)HAVE_YOU_EXAMINED, "forest and the trees?", (string)DO_WHAT_WOODCUTTERS_DO;
      if (fire in nothing && logs hasnt moved)
        "Those logs", (string)MIGHT_COME_IN_HANDY;
      if (room04 hasnt visited)
        print_ret (string)HEAD_TO_VILLAGE;
    Smell:
      print_ret (string)YOU_SMELL_SMOKE;
  ],
has light;

!----------------------------------------
! Forest (floating object)
!----------------------------------------
Object "forest"
with
  article THE,
  name 'forest' 'woods' 'fringe' 'of' 'deep',
  description "The forest is full of trees, so it's where you spend your time felling timber and chopping wood. It's normally a peaceful place, but it's now tainted by the smell of smoke in the air.",
  found_in room01 room02,
has scenery;

!----------------------------------------
! Smoke (floating object)
!----------------------------------------
Object "smoke"
with
  name 'smoke' 'faint' 'wisp' 'of',
  description "You see a faint wisp of smoke rising from the village.",
  found_in room01 room02 room04,
has scenery;

!----------------------------------------
! Trees
!----------------------------------------
Object "trees" room01
with
  name 'tree' 'trees' 'wood' 'timber' ,
  description "The trees in this forest make good building materials and the dead ones make good firewood. There are enough trees here to keep you busy for a long, long time.",
  before
  [;
    Climb:
      "You're a woodcutter, not a monkey. If you want to get to the top of a tree, you'll have to chop it down first.";
    Cut:
      if (CantBeChopped())
        rtrue;
      if (logs notin nothing)
        "You've chopped down enough trees for one day.";
      move logs to location;
      "You set to work with your trusty axe and chop down a dead tree that looks like it would make good firewood. You then chop it up into smaller logs.";
  ],
has pluralname scenery;

!----------------------------------------
! Logs
!----------------------------------------
Object logs "logs"
with
  name 'log' 'logs',
  description
  [;
    print "They're the logs you chopped from the forest behind your shack.";
    if (self has general)
      print " They're", (string)TOO_WET_TO_BURN;
    "";
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      if (location ~= room10)
        print_ret (string)NOT_APPROPRIATE_PLACE_FOR_FIRES;
      move fire to location;
      fire.fuel = self;
      move self to limbo;
      print_ret (string)YOU_USE_CANDLE_TO_SET_FIRE_TO, (the)self, ". As they're quite large, it takes a while for the flames to catch hold, but once they do, ", (string)YOU_SOON_HAVE_NICE_LITTLE_FIRE;
    Sharpen:
      if (second == nothing && axe in player)
      {
        print "(with the axe)^";
        second = axe;
      }
      if (second == nothing)
        print_ret(string)CANT_SEE_ANYTHING_HERE_TO_SHARPEN, (the)self, ".";
      if (second ~= axe)
        print_ret (string)YOU_CANT_SHARPEN, "logs with ", (ThatOrThose)second, ".";
      "You don't have time for that.";
  ],
has pluralname;

!========================================
! Room 2: Behind Your Shack
!========================================
Object room02 "Behind Your Shack"
with
  description "You're in the back yard behind your shack. The yard is surrounded by a fence with a gap leading into the forest to the north. There's a woodpile stacked against the back wall of the shack to the south, apart from a gap where the back door leads inside. A faint smell of smoke taints the air around you.",
  n_to room01,
  s_to back_door,
  in_to back_door,
  before
  [;
    Hint:
      if (shovel hasnt moved)
        "That shovel", (string)MIGHT_COME_IN_HANDY;
      if (firewood in nothing)
        "Examine the woodpile", (string)AND_DO_WHAT_IS_SUGGESTED;
      if (fire in nothing && firewood hasnt moved)
        "That firewood", (string)MIGHT_COME_IN_HANDY;
      if (room03 hasnt visited && back_door hasnt open)
        "Open the back door.";
      if (room03 hasnt visited)
        "Enter your shack.";
    Smell:
      print_ret (string)YOU_SMELL_SMOKE;
  ],
has light;

!----------------------------------------
! Back yard
!----------------------------------------
Object "back yard" room02
with
  article THE,
  name 'back' 'yard' 'backyard' 'ground' 'hard-packed' 'dirt' 'earth' 'soil',
  description "It's the back yard behind your shack. The ground consists of hard-packed dirt from where you've been walking all over it.",
  before
  [;
    Dig:
      "Don't waste your time. If there was gold buried in your own back yard, I'm sure you'd know about it.";
  ],
has scenery;

!----------------------------------------
! Shack (floating object)
!----------------------------------------
Object "wooden shack"
with
  name 'shack' 'simple' 'wooden' 'home',
  describe 2, !PunyInform 6.6 hack
  description "It's a simple wooden shack, but it's home.",
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      "Don't be silly. This is your home!";
    Enter:
      if (self in room02)
        <<Go FAKE_S_OBJ>>;
      if (self in room04)
        <<Go FAKE_W_OBJ>>;
    Exit:
      if (self in room03)
        print_ret (string)TWO_EXITS_TO_NORTH_AND, "east, so you'll have to specify which direction.";
  ],
  found_in room02 room03 room04,
has static; !Describe 2 makes this scenery

!----------------------------------------
! Fence
!----------------------------------------
Object "fence" room02
with
  name 'rickety' 'fence',
  description "The fence around the yard is quite rickety, so don't get any funny ideas about climbing over it. You must get around to replacing it one of these days.",
  before
  [;
    Climb:
      "Don't be silly. The fence would collapse under your weight.";
    Repair:
      "You'll get around to repairing it one of these days, but not now. It will have to wait until later.";
  ],
has scenery;

!----------------------------------------
! Gap
!----------------------------------------
Object "gap" room02
with
  name 'gap',
  description "The gap in the fence leads into the forest.",
  before
  [;
    Enter:
      <<Go FAKE_N_OBJ>>;
  ],
has scenery;

!----------------------------------------
! Back wall
!----------------------------------------
Object "back wall" room02
with
  name 'back' 'wall',
  description "The back wall of your shack serves to hold up the roof and support the woodpile.",
has scenery;

!----------------------------------------
! Woodpile
!----------------------------------------
Object "woodpile" room02
with
  name 'woodpile' 'pile' 'of' 'wood',
  description
  [;
    print "It's a pile of wood, neatly stacked against the back wall of your shack.";
    if (firewood in nothing)
      print " If you were to search it, I'm sure you could find some loose pieces that would be suitable to use as firewood.";
    "";
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      "The woodpile is stacked against the back wall of the shack. ", (string)YOUD_BURN_DOWN_YOUR_HOME;
    Search:
      if (firewood in nothing)
      {
        move firewood to location;
        "You search the woodpile and find some loose pieces of firewood that you place in a pile.";
      }
  ],
has scenery;

!----------------------------------------
! Firewood
!----------------------------------------
Object firewood "firewood"
with
  article SOME,
  name 'firewood' 'small' 'pile' 'of' 'wood',
  description
  [;
    print "It's a small pile of firewood that you scavenged from the woodpile behind your shack.";
    if (self has general)
      print " It's", (string)TOO_WET_TO_BURN;
    "";
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      if (location ~= room10)
        print_ret (string)NOT_APPROPRIATE_PLACE_FOR_FIRES;
      move fire to location;
      fire.fuel = self;
      move self to limbo;
      print_ret (string)YOU_USE_CANDLE_TO_SET_FIRE_TO, (the)self, ". It quickly catches light and ", (string)YOU_SOON_HAVE_NICE_LITTLE_FIRE;
  ],
has;

!----------------------------------------
! Shovel
!----------------------------------------
Object shovel "shovel" room02
with
  name 'shovel',
  description "It's the shovel you use to dig a hole when you go for a bog.",
has;

!========================================
! Room 3: Your Shack
!========================================
Object room03 "Your Shack"
with
  description "This is your wooden shack. It may seem simple, as it has very little in the way of furniture, but that's just the way you like it. The back door is to the north and the front door is to the east.",
  n_to back_door,
  e_to front_door,
  out_to MULTIPLE_EXITS,
  before
  [;
    Hint:
      if (meat hasnt moved)
        "That dried meat", (string)MIGHT_COME_IN_HANDY;
      if (room05 has visited && chair hasnt moved)
        "That chair", (string)MIGHT_COME_IN_HANDY;
      if (fire in nothing && logs hasnt moved && firewood hasnt moved && chopped_bed in nothing)
        "Your bed is made of wood.";
      if (room04 hasnt visited && front_door hasnt open)
        "Open the front door.";
      if (room04 hasnt visited)
        print_ret (string)HEAD_TO_VILLAGE;
  ],
has light;

!----------------------------------------
! Doors
!----------------------------------------
Object "doors" room03
with
  name 'doors',
  description
  [;
    print "There are two doors leading out of your shack. The front door to the east is ";
    if (front_door has open)
      print "open";
    else
      print "closed";
    print " and the back door to the north is ";
    if (back_door has open)
      "open.";
    else
      "closed.";
  ],
  before
  [;
    Close:
      print "Front door: ";
      <Close front_door>;
      print "Back door: ";
      <Close back_door>;
      rtrue;
    Open:
      print "Front door: ";
      <Open front_door>;
      print "Back door: ";
      <Open back_door>;
      rtrue;
  ],
has scenery;

!----------------------------------------
! Back door (floating object)
!----------------------------------------
Object back_door "back door"
with
  name 'back' 'door',
  description
  [;
    print "It's the back", (string)DOOR_OF_YOUR_SHACK;
    if (self hasnt open)
      "closed.";
    print (string)OPEN_AND_LEADS;
    if (self in room03)
      "outside.";
    else
      "inside.";
  ],
  door_dir
  [;
    if (self in room03)
      return n_to;
    else
      return s_to;
  ],
  door_to
  [;
    if (self in room03)
      return room02;
    else
      return room03;
  ],
  found_in room02 room03,
has door openable scenery;

!----------------------------------------
! Front door (floating object)
!----------------------------------------
Object front_door "front door"
with
  name 'front' 'door',
  description
  [;
    print "It's the front", (string)DOOR_OF_YOUR_SHACK;
    if (self hasnt open)
      "closed.";
    print (string)OPEN_AND_LEADS;
    if (self in room03)
      "outside.";
    else
      "inside.";
  ],
  door_dir
  [;
    if (self in room03)
      return e_to;
    else
      return w_to;
  ],
  door_to
  [;
    if (self in room03)
      return room04;
    else
      return room03;
  ],
  found_in room03 room04,
has door openable scenery;

!----------------------------------------
! Furniture
!----------------------------------------
Object "furniture" room03
with
  name 'furniture',
  description
  [;
    print "There's only ";
    if (bed in location)
      print (a)bed;
    else
      print (a)chopped_bed;
    if (chair in location)
      print " and ", (a)chair;
    ".";
  ],
has scenery;

!----------------------------------------
! Wooden bed
!----------------------------------------
Object bed "wooden bed" room03
class Surface
with
  article "your",
  name 'wooden' 'bed',
  description
  [;
    print "It's a roughly-hewn wooden bed. ";
    <<Search self>>;
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      print_ret (string)HAVE_TO_CHOP_IT_UP_FIRST;
    Cut:
      if (CantBeChopped())
        rtrue;
      while (child(self) ~= 0)
        move child(self) to location;
      remove self;
      move chopped_bed to location;
      PronounNotice(chopped_bed);
      "You chop your bed into pieces. Where are you going to sleep now?";
  ],
  after
  [;
    Enter:
      "You get onto your bed.";
    Exit:
      "You get off your bed.";
  ],
has enterable static supporter;

!----------------------------------------
! Chopped-up bed
!----------------------------------------
Object chopped_bed "chopped-up bed"
with
  name 'chopped-up' 'wooden' 'bed' 'splintered' 'wood',
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'chopped-up' or 'chopped' or 'wooden' or 'bed' or 'splintered' or 'wood')
    {
      i++;
      if (nw == 'chopped' or 'wood' && TestScope(wood))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "It's your former bed, now a pile of splintered wood.",
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      print_ret (string)YOUD_BURN_DOWN_YOUR_HOME;
    Cut:
      "You can't chop it much smaller.";
    Take:
      if (wood notin nothing)
        print_ret (string)YOUVE_ALREADY_TAKEN_SOME, "Leave the rest so that you can make another bed later.";
      if (children(player) >= MAX_CARRIED)
      {
        PrintMsg(MSG_TAKE_NO_CAPACITY);
        rtrue;
      }
      move wood to player;
      PronounNotice(wood);
      "You grab a few pieces of wood", (string)FROM_YOUR_CHOPPED_UP_BED;
  ],
has static;

!----------------------------------------
! Chopped wood
!----------------------------------------
Object wood "chopped wood"
with
  name 'pieces' 'of' 'chopped' 'wood',
  description
  [;
    print "It's the wood that you took", (string)FROM_YOUR_CHOPPED_UP_BED;
    if (self has general)
      print " It's", (string)TOO_WET_TO_BURN;
    "";
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      if (location ~= room10)
        print_ret (string)NOT_APPROPRIATE_PLACE_FOR_FIRES;
      move fire to location;
      fire.fuel = self;
      move self to limbo;
      print_ret (string)YOU_USE_CANDLE_TO_SET_FIRE_TO, (the)self, ". It takes a while for the flames to catch hold, but once they do, ", (string)YOU_SOON_HAVE_NICE_LITTLE_FIRE;
  ],
has pluralname;

!----------------------------------------
! Wooden chair
!----------------------------------------
Object chair "wooden chair" room03
class Surface
with
  name 'wooden' 'chair',
  description
  [;
    print "It's a wooden chair that you crafted yourself. ";
    <<Search self>>;
  ],
  react_before
  [;
    Drop:
      if (player in self && noun in player && noun hasnt worn)
      {
        move noun to location;
        print (The)noun, " fall";
        if (noun hasnt pluralname)
          print "s";
        print_ret " to the floor.";
      }
    Take:
      if (player in self && noun in location && noun hasnt scenery or static)
        "You can't reach ", (the)noun, " while you're standing on the chair.";
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      print_ret (string)HAVE_TO_CHOP_IT_UP_FIRST;
    Climb:
      if (self in player)
        print_ret (string)HAVE_TO_DROP_IT_FIRST;
      if (player in self)
        <<Exit self>>;
      else
        <<Enter self>>;
    Cut:
      if (CantBeChopped())
        rtrue;
      "This is your favourite chair. You made it yourself. You don't have the heart", (string)TO_CHOP_INTO_FIREWOOD;
    Enter:
      if (self in player)
        print_ret (string)HAVE_TO_DROP_IT_FIRST;
      if (player in self)
        "You're already standing on it.";
      if (verb_word == 'lie')
        "It's not big enough to lie on.";
      if (child(self) ~= 0)
        "You'll have to take everything off the chair first.";
      if (self notin location)
        "You need to put it on the ground before you can get on it.";
      if (verb_word == 'sit')
        "You sit down to ponder your current situation, then stand up again.";
    Go:
      if (selected_direction == u_to)
      {
        if (location == room05)
        {
          if (trapdoor hasnt open)
            print "You'll have to open the trapdoor first.^";
          else
          {
            print "You clamber through the trapdoor^^";
            PlayerTo(room06, 2);
          }
          return 2;
        }
        print "You can't climb any higher.^";
        return 2;
      }
      if (selected_direction == d_to)
      {
        <Exit self>;
        return 2;
      }
      print "You'll have to get off the chair first.^";
      return 2;
  ],
  after
  [;
    Enter:
      "You stand on the chair. It's a bit wobbly.";
    Exit:
      "You step down from the chair.";
  ],
has enterable supporter;

!----------------------------------------
! Dried meat
!----------------------------------------
Object meat "dried meat" room03
with
  article SOME,
  name 'dried' 'meat' 'ham',
  description "It's dried ham that feels as tough as old boots.",
  before
  [;
    Eat, Taste:
      "It's too dry. You'd need to soak it in water or boil it before it's edible.";
    Insert, ThrowAt:
      if (second == river or bulk_water)
      {
        move self to limbo;
        give fish absent;
        MoveFloatingObjects();
        "When you throw the dried meat into the river, it suddenly starts churning with man-eating fish all fighting to get their share. As the meat floats downstream, the man-eating fish follow it, leaving the river clear to cross.";
      }
    PutOn:
      if (second == fire)
        "The meat is already dried. If you put it on the fire, you'll burn it to a cinder,";
    Touch:
      <<Examine self>>;
  ],
has;

!========================================
! Room 4: Village Centre
!========================================
Object room04 "Village Centre"
with
  description
  [;
    print "You're standing in the centre of the remains of Cessnock village. Many of the dwellings have been destroyed. Only a small huddle of buildings still stand nearby. Working clockwise, the village elder's house is to the north, a badly damaged baker's shop is to the northeast, the candlemaker's shop is to the east, the beekeeper's hut is to the south and the front door of your shack is to the west. There's also a path leading out of the village to the southeast.";
    if (self hasnt visited)
      print "^^The village is usually bristling with activity, but it's now silent. When you look around, you realise that every man, woman and child has been taken. It appears that the rumours were true and the wizard has plundered the village and kidnapped all the villagers.^^You vow to venture east to find the wizard and destroy him. With any luck, the villagers have only been captured and not killed, so you may still be able to save them.";
    "";
  ],
  n_to room05,
  s_to room09,
  e_to room07,
  w_to front_door,
  ne_to room08,
  se_to room11,
  in_to "There are multiple buildings here, so you'll have to tell me which one to enter or use a direction.",
  before
  [;
    Hint:
      if (room05 hasnt visited || room08 hasnt visited || room07 hasnt visited || room09 hasnt visited)
        "Make sure you explore all the buildings.";
      if (room13 hasnt visited)
        print_ret (string)FOLLOW_PATH;
    Smell:
      print_ret (string)YOU_SMELL_SMOKE;
  ],
has light;

!----------------------------------------
! Village centre (floating object)
!----------------------------------------
Object "village centre"
with
  article THE,
  name 'village' 'centre' 'center' 'clearing',
  description "It's a clearing with buildings around it.",
  found_in room04 room11,
has scenery;

!----------------------------------------
! Buildings
!----------------------------------------
Object "buildings" room04
with
  name 'building' 'buildings',
  description "You count five buildings around the village centre, two of them being shops. You can examine them individually, if you like.",
  before
  [;
    Enter:
      "As there are five buildings around", (string)TELL_ME_WHICH_ONE_TO_ENTER;
  ],
has pluralname scenery;

!----------------------------------------
! Shops
!----------------------------------------
Object "shops" room04
with
  name 'both' 'shop' 'shops',
  description "Both shops have been attacked and left partially ruined.",
  before
  [;
    Enter:
      "As there are two shops in", (string)TELL_ME_WHICH_ONE_TO_ENTER;
  ],
has pluralname scenery;

!----------------------------------------
! Elder's house (floating object)
!----------------------------------------
Object "elder's house"
with
  article THE,
  name 'elder^s' 'house',
  description "The elder's house is the tallest and only brick building in the village.",
  before
  [;
    Enter:
      if (self in room04)
        <<Go FAKE_N_OBJ>>;
    Exit:
      if (self in room04)
        <<Go FAKE_S_OBJ>>;
  ],
  found_in room04 room05,
has scenery;

!----------------------------------------
! Baker's shop (floating object)
!----------------------------------------
Object "baker's shop"
with
  article THE,
  name 'baker^s' 'shop',
  description "This was once a bustling shop, but it now stands forlorn and broken.",
  before
  [;
    Enter:
      if (self in room04)
        <<Go FAKE_NE_OBJ>>;
    Exit:
      if (self in room08)
        <<Go FAKE_SW_OBJ>>;
  ],
  found_in room04 room08,
has scenery;

!----------------------------------------
! Candlemaker's shop (floating object)
!----------------------------------------
Object "candlemaker's shop"
with
  article THE,
  name 'candlemaker^s' 'shop' 'rubble-filled' 'shell',
  description "You remember going to this shop as a child, and you still buy all your candles here. It's sad to see it in such a wrecked state. It's now nothing more than a rubble-filled shell.",
  before
  [;
    Enter:
      if (self in room04)
        <<Go FAKE_E_OBJ>>;
    Exit:
      if (self in room07)
        <<Go FAKE_W_OBJ>>;
  ],
  found_in room04 room07,
has scenery;

!----------------------------------------
! Beekeeper's hut (floating object)
!----------------------------------------
Object "beekeeper's hut"
with
  article THE,
  name 'beekeeper^s' 'hut' 'wooden' 'shell',
  description "The hut is made of wood, slightly smaller than your own shack, and now derelict. All that's left is a wooden shell.",
  before
  [;
    Enter:
      if (self in room04)
        <<Go FAKE_S_OBJ>>;
      if (self in room10)
        <<Go FAKE_N_OBJ>>;
    Exit:
      if (self in room09)
        print_ret (string)TWO_EXITS_TO_NORTH_AND, "south.";
  ],
  found_in room04 room09,
has scenery;

!----------------------------------------
! Path (floating object)
!----------------------------------------
Object "path"
with
  name 'path' 'well-tracked',
  description
  [;
    print "It's a well-tracked path that leads through the meadows to the River Nudd further to the east.";
    if (self notin room04)
      print " The sides of the path are skirted by long grass and weeds.";
    "";
  ],
  found_in room04 room11 room12,
has scenery;

!========================================
! Room 5: Elder's House
!========================================
Object room05 "Elder's House"
with
  description "You're in the deserted village elder's house. It was always one of the nicer dwellings in the village, but now it's emptied and wrecked. There's a trapdoor in the ceiling that provides access to the loft. The exit is to the south.",
  s_to room04,
  u_to
  [;
    if (player notin chair)
      "You can't reach the trapdoor from here.";
    return trapdoor;
  ],
  out_to room04,
  before
  [;
    Hint:
      if (room06 hasnt visited && player notin chair)
        "If you have lofty expectations, just step up to greater heights.";
      if (room06 hasnt visited && trapdoor hasnt open)
        "Open the trapdoor.";
      if (room06 hasnt visited)
        "Enter the trapdoor.";
  ],
has light;

!----------------------------------------
! Ceiling
!----------------------------------------
Object "ceiling" room05
with
  article THE,
  name 'ceiling',
  description "There's a trapdoor in the ceiling.",
has scenery;

!----------------------------------------
! Loft
!----------------------------------------
Object "loft" room05
with
  name 'loft' 'entrance',
  description "The loft is on the other side of the ceiling. You'll need to climb through the trapdoor to get to it.",
has scenery;

!----------------------------------------
! Trapdoor
!----------------------------------------
Object trapdoor "trapdoor" room05
with
  name 'trapdoor' 'trap' 'door',
  description
  [;
    print "It's a trapdoor in the ";
    if (self in room05)
      print "ceiling";
    else
      print "floor";
    print " that's currently ";
    if (self has open)
      "open.";
    else
      "closed.";
  ],
  door_dir
  [;
    if (self in room05)
      return u_to;
    else
      return d_to;
  ],
  door_to
  [;
    if (self in room05)
      return room06;
    else
      return room05;
  ],
  before
  [;
    if (action ~= ##Examine && self in room05 && player notin chair)
      "You can't reach it.";
  ],
  found_in room05 room06,
has door openable scenery;

!========================================
! Room 6: Loft
!========================================
Object room06 "Loft"
with
  description "You're in the loft of the village elder's house. The roof tiles are mostly in place, but there are narrow cracks through which you can see the wild lands off to the east and the surrounding devastation of burnt buildings in many directions. The only way out is down through the trapdoor.",
  d_to
  [;
    if (trapdoor hasnt open)
      return trapdoor;
    print "You carefully lower yourself onto the chair.^^";
    PlayerTo(chair, 2);
    rtrue;
  ],
  before
  [;
    Go:
      if (selected_direction == out_to)
        <<Go FAKE_D_OBJ>>;
    Hint:
      if (book hasnt general)
        "Reading is good for the soul.";
      if (polish hasnt moved)
        "That tub of metal polish may come in handy.";
  ],
has light;

!----------------------------------------
! Loft
!----------------------------------------
Object "loft" room06
with
  name 'loft' 'darkness',
  description "It's a small space under the roof. Daylight enters through several gaps in the tiles.",
has scenery;

!----------------------------------------
! Roof
!----------------------------------------
Object "roof" room06
with
  article THE,
  name 'roof',
  description "There are some gaps between the slate tiles, but the only thing that can get through them is daylight.",
has scenery;

!----------------------------------------
! Slate tiles
!----------------------------------------
Object "slate tiles" room06
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'roof' or 'several' or 'gap' or 'gaps' or 'slate' or 'tile' or 'tiles' or 'daylight' or 'narrow' or 'crack' or 'cracks' or 'daylight')
    {
      i++;
      if (nw == 'roof')
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "The slate tiles are quite big, hence immovable. Some gaps between the tiles allow the daylight to penetrate the darkness of the loft.",
has pluralname scenery;

!----------------------------------------
! Leather-bound book
!----------------------------------------
Object book "leather-bound book" room06
with
  name 'leather-bound' 'leather' 'bound' 'book',
  description
  [;
    print "It's a book about the history of these lands.";
    if (self hasnt general)
      print " You should probably read it to see if there's anything about the wizard.";
    "";
  ],
  before
  [;
    Read:
      give self general;
      "You find a section on the wizard. This part reads, 'The wizard is endowed with the ability to cast powerful magic spells. Witnesses have reported attacks on him with normal weapons, but these have been repelled with no effect. The wizard spends a lot of time in his bat-filled tower with the curtains drawn. Due to this unusual behaviour, it is suspected that he may also be a vampire.'";
  ],
has;

!----------------------------------------
! Small tub of metal polish
!----------------------------------------
Object polish "tub of metal polish" room06
with
  name 'small' 'tub' 'of' 'metal' 'polish',
  description "It's a small tub of something that has a strong chemical smell. You recognise it, with nostalgia, as something your mother used to polish the household brass and silver when you were a child, not that you ever had much brass and silver.",
has;

!========================================
! Room 7: Candlemaker's Shop
!========================================
Object room07 "Candlemaker's Shop"
with
  description "You stand under the open sky in what used to be the candlemaker's shop. It's been completely destroyed and nothing but rubble lies beneath your feet. The village centre is to the west.",
  w_to room04,
  out_to room04,
  before
  [;
    Hint:
      if (candle in nothing)
        "Examine the rubble", (string)AND_DO_WHAT_IS_SUGGESTED;
      if (candle hasnt moved)
        "That candle may come in handy.";
  ],
has light;

!----------------------------------------
! Rubble
!----------------------------------------
Object "rubble" room07
with
  article SOME,
  name 'rubble' 'broken' 'bits' 'of' 'wall' 'roof',
  description
  [;
    print "It's broken bits of wall and roof.";
    if (candle in nothing)
      print " You wonder if anything remains under the rubble.";
    "";
  ],
  before
  [;
    LookUnder, Pull, Push, Search:
      print "You search through the rubble and find ";
      if (candle notin nothing)
        "nothing else of value.";
      move candle to location;
      "a single candle that escaped the devastation.";
  ],
has scenery;

!----------------------------------------
! Candle
!----------------------------------------
Object candle "candle"
with
  name 'candle',
  short_name
  [;
    if (self has light)
      print "lit ";
    rfalse;
  ],
  invent
  [;
    if (inventory_stage == 2)
      rtrue;
  ],
  description
  [;
    print "It's a thin scraggly candle with a cotton wick.";
    if (self has light)
      print " It's currently lit and holds a fine flame despite being so thin.";
    "";
  ],
  before
  [;
    Burn:
      if (self has light)
        "It's already lit.";
      if (self notin player)
        "You don't have it.";
      if (second == nothing && TestScope(embers))
      {
        print "(with the embers)^";
        second = embers;
      }
      if (second == nothing)
        print_ret (string)YOU_DONT_HAVE_ANYTHING, "to light it with.";
      if (second ~= embers)
        "You can't light the candle with ", (the)second, ".";
      give self light;
      "You light the candle with the embers in the oven.";
    Extinguish:
      if (self hasnt light)
        "It's not lit.";
      give self ~light;
      "You blow out the candle.";
  ],
has;

!========================================
! Room 8: Baker's Shop
!========================================
Object room08 "Baker's Shop"
with
  description "You're in the shell of the baker's shop. This used to be full of the aromatic smell of fresh bread and pastries, but now it stands empty, apart from one characteristic structure in the corner. There's a wrecked doorway to the southwest.",
  sw_to room04,
  out_to room04,
  before
  [;
    Hint:
      if (jug hasnt moved)
        "That jug may come in handy.";
      if (candle in nothing)
        "Come back later.";
      if (fire in nothing)
      {
        if (candle hasnt light)
        {
          if (oven hasnt open)
            "Open the oven.";
          else
            "Those embers look hot enough to light a candle.";
        }
        "You'll need to start a fire somewhere, but not here.";
      }
  ],
has light;

!----------------------------------------
! Corner
!----------------------------------------
Object "corner" room08
with
  name 'one characteristic structure' 'corner',
  description "The structure in the corner is an oven.",
has scenery;

!----------------------------------------
! Doorway
!----------------------------------------
Object "doorway" room08
with
  name 'wrecked' 'doorway',
  description "The doorway is broken and leads back to the village centre.",
has scenery;

!----------------------------------------
! Clay oven
!----------------------------------------
Object oven "clay oven" room08
class OpenableContainer
with
  name 'clay' 'oven',
  description
  [;
    print "It's a clay oven that the baker uses to bake bread and pastries. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun == firewood or logs or rotten_wood or wood)
        "You could certainly put ", (the)noun, " in the oven to stoke the fire, but this is no time to be thinking about baking bread.";
      else
        "You should only put fuel in the oven.";
  ],
has container openable static;

!----------------------------------------
! Embers
!----------------------------------------
Object embers "embers" oven
with
  name 'embers',
  description "The embers are still hot.",
  before
  [;
    Extinguish:
      if (jug in player && water in jug)
        <<EmptyT jug self>>;
      print_ret (string)YOU_HAVE_NOTHING_TO_EXTINGUISH, (the)self, ".";
    Take:
      "The embers are too hot to pick up.";
  ],
has pluralname static;

!----------------------------------------
! Jug
!----------------------------------------
Object jug "jug" room08
class OpenContainer
with
  name 'jug' 'fragile-looking' 'fragile' 'looking' 'earthenware' 'pottery',
  description
  [;
    print "It's a fragile-looking jug with a slight crack in the side. It's earthenware pottery, by the looks of it. ";
    <<Search self>>;
  ],
  before
  [;
    Attack:
      if (fire in nothing || fire hasnt general)
        "You'd best not. You never know, but you might need it later.";
      print "Suspecting that you won't need the jug any more, you give it a good whack and break it into pieces. ";
      if (water in self)
      {
        remove water;
        print "The water splashes out and soaks into the ground. ";
      }
      move pottery to parent(self);
      remove self;
      "You're now left with just a sharp chunk of pottery.";
    Drink:
      "You can drink water or drink from the jug, but you can't drink the jug itself. That wouldn't fit down your throat.";
    DrinkFrom:
      if (water notin self)
        "The jug is empty.";
      <<Drink water>>;
    Empty, Turn:
      if (self notin player)
      {
        print "(first taking the jug)^";
        move self to player;
      }
      if (water notin self)
        "The jug is empty.";
      remove water;
      "When you turn the jug upside down, the water soaks into the ground.";
    EmptyT:
      if (child(self) == 0)
        "There's nothing in the jug to pour out.";
      if (second == embers)
        "That's probably not a good idea. What if you need them for something?";
      if (second ~= fire)
        <<Empty self>>;
      remove water;
      print "You pour the water onto the fire and ";
      if (fire hasnt general)
      {
        give fire general;
        "it starts smoking. The smoke seems to have calmed the bees.";
      }
      move fire.fuel to location;
      give fire.fuel general;
      give fire ~general;
      remove fire;
      "put it out.";
    Fill:
      if (water in self)
        print_ret (string)ITS_ALREADY_FULL;
      if (TestScope(bulk_water))
      {
        print "(with water)^";
        <<FillWith self bulk_water>>;
      }
    FillWith:
      if (water in self)
        print_ret (string)ITS_ALREADY_FULL;
      if (second ~= bulk_water)
        <<Insert second self>>;
      move water to self;
      "You fill the jug with water.";
    Pour:
      "The jug is not a liquid. You can pour its contents into or onto something, or you can empty it into or onto something, assuming that's what you're trying to do.";
    Receive:
      if (noun ~= bulk_water)
        "You can only put water in the jug.";
  ],
has container open;

!----------------------------------------
! Sharp piece of pottery
!----------------------------------------
Object pottery "sharp piece of pottery"
with
  name 'sharp' 'piece' 'of' 'pottery',
  description "It's a remnant of the jug and has a keen edge to it.",
has;

!========================================
! Room 9: Beekeeper's Hut
!========================================
Object room09 "Beekeeper's Hut"
with
  description "You're inside the beekeeper's hut. It's been stripped bare, but the structure remains mostly intact. A low hum can be heard coming from the exit to the south. You can return to the village centre to the north.",
  n_to room04,
  s_to room10,
  out_to MULTIPLE_EXITS,
  before
  [;
    Hint:
      if (room10 hasnt visited)
        "What's that hum to the south?";
    Listen:
      print_ret (string)YOU_HEAR_BEES;
  ],
has light;

!========================================
! Room 10: Meadow Behind Beekeeper's Hut
!========================================
Object room10 "Meadow Behind Beekeeper's Hut"
with
  description "You're in a small meadow south of the beekeeper's hut. The constant buzzing of bees betrays its purpose and the sweet smell of honey does its best to dampen the smell of destruction that permeates the air around here.",
  n_to room09,
  in_to room09,
  before
  [;
    Hint:
      if (fire in nothing)
      {
        print "It's a well-known fact that smoke pacifies bees, but smoke requires a fire. ";
        if (firewood notin self && logs notin self && rotten_wood notin self && wood notin self)
          "Start by finding some fuel.";
        if (candle in nothing || candle hasnt light)
          "Find something to light the fuel.";
        else
          "Light the fuel.";
      }
      if (fire hasnt general)
        "Pouring water on a fire will make it smoky.";
      if (honeycomb in beehive)
        "What's in the beehive?";
    Listen:
      print_ret (string)YOU_HEAR_BEES;
    Smell:
      if (fire in self && fire has general)
        print_ret (string)YOU_SMELL_SMOKE;
      else
        "You can smell honey.";
  ],
has light;

!----------------------------------------
! Meadow
!----------------------------------------
Object "meadow" room10
with
  name 'small' 'meadow',
  description "The meadow houses a large man-made beehive that the bees call home.",
has scenery;

!----------------------------------------
! Bees
!----------------------------------------
Object "bees" room10
with
  name 'bees',
  description
  [;
    print "They're little black and yellow stripey things that can give you a nasty sting if you annoy them. They're currently ";
    if (fire notin location || fire hasnt general)
      "buzzing around the beehive as they go about their business.";
    else
      "keeping away from the beehive because of the smoke from the fire.";
  ],
has pluralname scenery;

!----------------------------------------
! Beehive
!----------------------------------------
Object beehive "beehive" room10
class OpenableContainer
with
  name 'beehive' 'beehives' 'bee' 'hive' 'hives',
  description
  [;
    print "The beehive is made of wood with a hinged lid on the top and emanates buzzing noises. ";
    <<Search self>>;
  ],
  before
  [;
    if (action ~= ##Examine && (fire notin location || fire hasnt general))
      "The buzzing bees prevent you getting any closer to the beehive.";
    Receive:
      if (noun ~= honeycomb)
        "The bees wouldn't be very happy about you leaving ", (a)noun, " in their beehive.";
  ],
has container openable static;

!----------------------------------------
! Hinged lid
!----------------------------------------
Object "hinged lid" room10
with
  name 'hinged' 'lid' 'roof',
  description
  [;
    print "The hinged lid is like a little roof to protect whatever's inside the beehive. The lid is currently ";
    if (beehive has open)
      "open.";
    else
      "closed.";
  ],
  before
  [;
    Close:
      <<Close beehive>>;
    Open:
      <<Open beehive>>;
  ],
has scenery;

!----------------------------------------
! Honeycomb
!----------------------------------------
Object honeycomb "chunk of honeycomb" beehive
with
  name 'large' 'chunk' 'of' 'honeycomb' 'golden' 'honey' 'comb',
  description "It's a large chunk of honeycomb oozing with golden honey.",
  before
  [;
    Eat, Taste:
      "You lick some of the honey from the honeycomb. Yum! This will be a good source of energy, so you decide not to eat it all in case you need it later.";
  ],
has;

!----------------------------------------
! Small fire
!----------------------------------------
Object fire "fire"
with
  name 'small' 'smoke' 'smoky' 'smokey' 'fire',
  short_name
  [;
    if (self hasnt general)
      print "small ";
    else
      print "smoky ";
    rfalse;
  ],
  invent
  [;
    if (inventory_stage == 2)
      rtrue;
  ],
  description
  [;
    print "The small fire ";
    if (self hasnt general)
      "crackles heartily and generates a small amount of heat, but no smoke.";
    else
      "pours out a great deal of smoke that seems to be keeping the bees away.";
  ],
  before
  [;
    Burn:
      "It's already lit.";
    Extinguish:
      if (jug in player && water in jug)
        <<EmptyT jug self>>;
      print_ret (string)YOU_HAVE_NOTHING_TO_EXTINGUISH, (the)self, ".";
    Take:
      "Ouch! You burn your fingers. It serves you right for being so stupid. If you want to take ", (the)self.fuel, " you'll have to douse the fire first.";
  ],
  fuel firewood,
has light static;

!========================================
! Room 11: Path to Village
!========================================
Object room11 "Path to Village"
with
  description "You're on a path that leads through a meadow from the village of Cessnock to the northwest, then continues to the east. Apart from the remains of the village, you can see further burnt shells of houses in the distance.",
  e_to room12,
  nw_to room04,
  before
  [;
    Hint:
      if (room13 hasnt visited)
        print_ret (string)FOLLOW_PATH;
  ],
has light;

!----------------------------------------
! Meadow (floating object)
!----------------------------------------
Object "meadow"
with
  name 'sunny' 'meadow' 'long' 'grass' 'weeds',
  description "The long grass and weeds in the meadow make good grazing land for sheep and goats, but there's no longer any animals grazing here.",
  found_in room11 room12,
has scenery;

!----------------------------------------
! Animals (floating object)
!----------------------------------------
Object "animals"
with
  name 'sheep' 'goat' 'goats' 'animal' 'animals',
  description "The sheep and goats are all gone. Maybe the wizard took them, as well as the villagers.",
  before
  [;
    if (action ~= ##Examine)
    {
      PrintMsg(MSG_PARSER_NOSUCHTHING);
      rtrue;
    }
  ],
  found_in room11 room12,
has pluralname scenery;

!----------------------------------------
! Burnt shells of houses
!----------------------------------------
Object "houses" room11
with
  name 'burnt' 'shells' 'of' 'houses' 'stores',
  description "The houses are in the distance and there are no paths to them from here, but it's a sorry sight that angers you and increases your resolve to find and kill that wizard.",
  before
  [;
    if (action ~= ##Examine)
      "The houses are too far away.";
  ],
has pluralname scenery;

!========================================
! Room 12: Path Through Meadow
!========================================
Object room12 "Path Through Meadow"
with
  description "You're under a clear blue sky in a sunny meadow. The air is clearer here, though smoke still rises from the remains of the village to the west. A gentle slope leads down to bushes around a river to the east.",
  e_to room13,
  w_to room11,
  before
  [;
    Hint:
      if (room13 hasnt visited)
        print_ret (string)FOLLOW_PATH;
  ],
has light;

!----------------------------------------
! Bushes
!----------------------------------------
Object "bushes" room12
with
  name 'bushes',
  description "The bushes get denser towards the east.",
has pluralname scenery;

!========================================
! Room 13: West Riverbank
!========================================
Object room13 "West Riverbank"
with
  description
  [;
    print_ret (string)WEST_BANK_OF_RIVER_NUDD, ", whose clear, frothy waters flow quickly over the tops of hidden boulders. The riverbank continues to the north and south, and the meadows are back to the west.";
  ],
  n_to room15,
  s_to room14,
  e_to TOO_DEEP_TO_CROSS_HERE,
  w_to room12,
  before
  [;
    Hint:
      if (fire notin nothing && fire hasnt general)
        print_ret (string)GOOD_PLACE_TO_GET_WATER;
      if (room17 hasnt visited)
        print_ret (string)NEED_TO_GET_ACROSS_RIVER;
    Swim:
      <<Enter river>>;
  ],
has light;

!----------------------------------------
! Riverbank (floating object)
!----------------------------------------
Object "riverbank"
with
  name 'riverbank' 'west' 'bank' 'muddy' 'path',
  description "It's a muddy path with the River Nudd to the east of it. It has foliage on both sides and tiny darting insects that sparkle in the sunlight.",
  found_in room13 room14 room15,
has scenery;

!----------------------------------------
! River Nudd (floating object)
!----------------------------------------
Object river "River Nudd"
with
  article THE,
  name 'river' 'nudd' 'clear' 'frothy' 'waters',
  description
  [;
    print "This river is the source of water for the village, though no one ever swims here because of the man-eating fish. The river is ";
    if (self in room13)
      "fast-flowing at this point, and full of boulders. It's too wide to jump across, so don't get any funny ideas.";
    if (self in room14)
      "deep at this point, clearly deep enough for boats.";
    else
      "quite shallow here, but still too wide to jump across to the other side.";
  ],
  before
  [;
    Enter:
      if (self in room17)
        <<Go FAKE_W_OBJ>>;
      else
        <<Go FAKE_E_OBJ>>;
    Receive, ThrownAt:
      print_ret (string)NO_NEED_TO_THROW_ANYTHING_IN_RIVER;
  ],
  found_in room13 room14 room15 room17,
has scenery;

!----------------------------------------
! Bulk water (floating object)
!----------------------------------------
Object bulk_water "water"
with
  article SOME,
  name 'water',
  parse_name
  [;
    if (TestScope(water))
      return 0;
    else
      return -1;
  ],
  description
  [;
    print "The water looks clean";
    if (fish in location)
      print " and this allows you to see the man-eating fish swimming about";
    if (self in room15 or room17)
      print ". The water is shallower here, but still not wide enough to jump across";
    ".";
  ],
  before
  [;
    Drink:
      if (fish in location)
        <<Take fish>>;
      else
        print_ret (string)VERY_REFRESHING;
    Enter:
      if (self in room17)
        <<Go FAKE_W_OBJ>>;
      else
        <<Go FAKE_E_OBJ>>;
    Insert:
      <<Take self second>>;
    Receive, ThrownAt:
      print_ret (string)NO_NEED_TO_THROW_ANYTHING_IN_RIVER;
    Remove:
      if (second == jug && jug in player)
        <<Take self jug>>;
    Take:
      if (second == nothing && jug in player)
      {
        print "(with the jug)^";
        second = jug;
      }
      if (second == nothing && fish in location)
        <<Take fish>>;
      if (second == nothing)
        "The water trickles through your fingers. You'll need a container to put it in.";
      if (second ~= jug)
        "You need a container and ", (the)second, " ", (IsOrAre)second, " certainly not a container.";
      move water to second;
      PronounNotice(water);
      "You fill ", (the)second, " with water.";
  ],
  found_in room13 room14 room15 room17,
has scenery;

!----------------------------------------
! Water
!----------------------------------------
Object water "water"
with
  article SOME,
  name 'water',
  description "It's the water you got from the river.",
  before
  [;
    Drink:
      remove self;
      print_ret (string)VERY_REFRESHING;
    Insert, PourT, PutOn:
      if (second ~= fire or embers)
        rfalse;
      <<EmptyT (parent(self)) second>>;
    Take:
      "If you want to take the water out of the jug, you'll have to pour it out or empty the jug.";
  ],
has static;

!----------------------------------------
! Man-eating fish (floating object)
!----------------------------------------
Object fish "man-eating fish"
with
  name 'man-eating' 'fish',
  description "They're small fish with sharp teeth. Individually, they can't do too much harm, but hundreds of them can be fatal. You once saw a goat slip into the river and it was stripped clean in minutes.",
  life
  [;
    Answer, Ask, Talk, Tell:
      "Talking fish? Yeah, sure, very funny.";
    Attack:
      "If you were to attack the man-eating fish, I think I know who would come off second best, and it wouldn't be the fish.";
    Give:
      if (noun == meat)
        <<ThrowAt meat river>>;
    Kiss:
      "As you stoop down to kiss the fish, one of them leaps out of the water and nips you on the nose. Ouch! As you wipe the blood off on your sleeve, you think better of it.";
    Show:
      if (noun == meat)
        "You wave the meat above the surface of the water so that the fish can see it, and the water churns up as they try to jump out of the water to get to the meat.";
    WakeOther:
      "Do fish sleep? Who knows? Anyway, these ones aren't asleep.";
  ],
  before
  [;
    Take:
      "Are you crazy? Those fish would strip the flesh off your arm before you can say Jack Robinson.";
  ],
  found_in room13 room14 room15 room17,
has animate neuter pluralname scenery;

!----------------------------------------
! Insects (floating object)
!----------------------------------------
Object "insects"
with
  name 'insects',
  description "The bigger ones are dragonflies and the smaller ones are mosquitoes.",
  found_in room13 room14 room15 room16 room17,
has pluralname scenery;

!----------------------------------------
! Dragonflies (floating object)
!----------------------------------------
Object "dragonflies"
with
  name 'dragonfly' 'dragonflies',
  description "They're quite beautiful, but they aren't needed for anything.",
  found_in room13 room14 room15 room16 room17,
has pluralname scenery;

!----------------------------------------
! Mosquitoes (floating object)
!----------------------------------------
Object "mosquitoes"
with
  name 'mosquito' 'mosquitoes' 'mozzies',
  description "Be careful of the mosquitoes, as they can give you a nasty bite and suck your blood out.",
  found_in room13 room14 room15 room16 room17,
has pluralname scenery;

!----------------------------------------
! Boulders
!----------------------------------------
Object "boulders" room13
with
  name 'hidden' 'boulders',
  description "They're too far away. As they're underwater, you can't examine them properly, but they don't look especially inviting.",
has pluralname scenery;

!========================================
! Room 14: West Riverbank
!========================================
Object room14 "West Riverbank"
with
  description
  [;
    print (string)WEST_BANK_OF_RIVER_NUDD, ". The air is thick with mosquitoes that buzz around your face. Sunken into the side of the bank are the remains of a rotten wooden boat. The mast ";
    if (mast has scenery)
      print "seems solid enough, but";
    else
      print "has been chopped down and";
    " the hull is thick with moss. The path south is curtailed here, but you can return to the north.";
  ],
  n_to room13,
  e_to TOO_DEEP_TO_CROSS_HERE,
  before
  [;
    Hint:
      if (fire notin nothing && fire hasnt general)
        print_ret (string)GOOD_PLACE_TO_GET_WATER;
      if (mast has scenery)
        print_ret (string)HAVE_YOU_EXAMINED, "mast?", (string)DO_WHAT_WOODCUTTERS_DO;
      if (rope has scenery)
        "Try untying the rope for a handy hint.";
      if (anchor in nothing)
        "Examine the boat for a handy hint.";
      if (anchor hasnt moved)
        "That anchor may come in handy.";
      if (grappling_hook in nothing)
        "The rope can be tied to the anchor you know...or vice versa.";
      if (fire in nothing && rotten_wood in nothing)
        "There are several places where you can find dry wood.", (string)THIS_IS_ONE_OF_THEM;
      if (room17 hasnt visited)
        print_ret (string)NEED_TO_GET_ACROSS_RIVER;
    Swim:
      <<Enter river>>;
  ],
has light;

!----------------------------------------
! Boat
!----------------------------------------
Object "boat" room14
with
  name 'boat' 'wreck' 'wrecked' 'remains' 'of' 'old' 'rotten' 'wooden' 'shell' 'planks' 'hull' 'small' 'fishing' 'vessel',
  description
  [;
    print "It was probably a small fishing vessel before it became grounded. All that remains is a rotten shell, with a mast ";
    if (mast has scenery)
      print "that sticks out at an angle";
    else
      print "that's been chopped off";
    print ". It's covered in damp moss that indicates its age.";
    if (anchor in nothing)
      print " You wonder if there might be anything useful in the remains of the hull.";
    "";
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      "You have no reason to burn the boat.";
    Cut:
      if (CantBeChopped())
        rtrue;
      if (rotten_wood notin nothing)
        "You've chopped up enough of the boat for one day.";
      move rotten_wood to location;
      "You clear away some of the moss and chop into the side of the boat until you have a small pile of rotten wood.";
    LookUnder, Search:
      print "You poke around under the rotten planks of the hull";
      if (anchor notin nothing)
        ", but don't find anything else of use.";
      move anchor to location;
      " and find an anchor, so you drag it out into the sunlight.";
  ],
has scenery;

!----------------------------------------
! Moss
!----------------------------------------
Object "moss" room14
with
  article SOME,
  name 'moss' 'damp',
  description "It grows all over the hull and seems to attract the insects. The moss is damp, but the wood underneath is dry.",
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      "The moss is too damp to catch fire. The wood underneath is dry, though.";
  ],
has scenery;

!----------------------------------------
! Rotten wood
!----------------------------------------
Object rotten_wood "rotten wood"
with
  article SOME,
  name 'fragments' 'of' 'rotten' 'wood',
  description
  [;
    print "It's the fragments of the rotten wood that you chopped from the old boat.";
    if (self has general)
      print " It's", (string)TOO_WET_TO_BURN;
    "";
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      if (location ~= room10)
        print_ret (string)NOT_APPROPRIATE_PLACE_FOR_FIRES;
      move fire to location;
      fire.fuel = self;
      move self to limbo;
      print_ret (string)YOU_USE_CANDLE_TO_SET_FIRE_TO, (the)self, ". It was dry from being in the sun, so it quickly catches light and ", (string)YOU_SOON_HAVE_NICE_LITTLE_FIRE;
  ],
has;

!----------------------------------------
! Anchor
!----------------------------------------
Object anchor "anchor"
with
  article AN,
  name 'anchor' 'small',
  description "It's a small anchor from the wrecked boat. It's not very big, so you can carry it around if you need to.",
  before
  [;
    Tie:
      if (second == rope)
      {
        if (rope has scenery)
          "If you want to tie the anchor to the rope", (string)UNTIE_IT_FROM_TOP_OF_MAST_FIRST;
        move rope to limbo;
        move grappling_hook to parent(self);
        move self to limbo;
        PronounNotice(grappling_hook);
        "You tie the anchor to the rope.", (string)NOW_IT_LOOKS_LIKE_GRAPPLING_HOOK;
      }
  ],
has;

!----------------------------------------
! Mast
!----------------------------------------
Object mast "mast" room14
with
  name 'mast',
  description
  [;
    print "The mast ";
    if (self has scenery)
      print "reminds you of a tree in the forest, but stripped of its branches. It's tilted at quite an angle, along with the rest of the boat.";
    else
      print "has been chopped down, but it's too heavy to move.";
    if (rope has scenery)
    {
      print " There's still a rope tied to the top of the mast";
      if (self has scenery)
        print " and hanging towards the ground.";
      else
        print ", but at least you can get to it now.";
    }
    "";
  ],
  before
  [;
    Attack:
      "You take out your frustrations by giving the mast a good hiding. There, take that you mean old mast.";
    Climb:
      if (self has scenery)
        "There are no hand holds or foot holds, so climbing the mast is a no-go.";
      else
        "There's no need. Now that you've chopped it down, you can now get to it without any trouble.";
    Cut:
      if (CantBeChopped())
        rtrue;
      if (self hasnt scenery)
        "You've already chopped it down. There's no need to chop it down again and it would take far too long", (string)TO_CHOP_INTO_FIREWOOD;
      give self ~scenery static;
      "Oh, dearie, dearie me. I think you need glasses. This is a mast, not a tree. Nevertheless, you chop down the mast and it comes crashing to the ground.";
    Pull, Push, Take:
      if (self has scenery)
        "You might be strong, but you're not strong enough that you can snap a mast in two like a twig.";
      else
        "It rolls a bit, then rolls back again. The mast seems quite happy where it is.";
  ],
has scenery;

!----------------------------------------
! Rope
!----------------------------------------
Object rope "rope" room14
with
  name 'rope',
  description
  [;
    if (self has scenery)
      "It's tied to the mast.";
    else
      "It's the rope you cut from the mast.";
  ],
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      "You'd better not burn the rope, as it may be useful for something later on.";
    Climb:
      if (self has scenery && mast has scenery)
        "You awkwardly start to climb the rope, but it swings about like a pendulum and you start to feel giddy, so you jump back down.";
    Cut:
      if (self hasnt scenery)
        "You don't want to cut it any shorter or it won't be useful.";
      if (second == nothing && pottery in player)
      {
        print (string)WITH_SHARP_POTTERY;
        second = pottery;
      }
      if (second == nothing && axe in player)
      {
        print "(with the axe)^";
        second = axe;
      }
      if (second == nothing)
        print_ret (string)YOU_DONT_HAVE_ANYTHING, "sharp enough to cut it with.";
      if (second ~= pottery or axe)
        "You can't cut the rope with ", (the)second, ".";
      if (mast has scenery)
      {
        if (second == pottery)
          "You need to cut the rope from the top of the mast so that you've got a decent length, but the top of the mast ", (string)IS_OUT_OF_YOUR_REACH;
        else
          "You take a swing at the rope with your axe, but it just sways about in the breeze. The rope needs something solid behind it. ", (string)UNTIE_IT_FIRST;
      }
      give self ~scenery;
      "Using the chopped-down mast as a support, you cut through the rope with ", (the)second, ".";
    Pull:
      if (self has scenery)
        "It won't budge. It's tied to the top of the mast.";
    Take:
      if (self has scenery)
        print_ret (string)UNTIE_IT_FIRST;
    Tie:
      if (self has scenery)
        "If you want to tie the rope to anything", (string)UNTIE_IT_FROM_TOP_OF_MAST_FIRST;
      if (second == anchor)
      {
        move anchor to limbo;
        move grappling_hook to parent(self);
        move self to limbo;
        PronounNotice(grappling_hook);
        "You tie the rope to the anchor.", (string)NOW_IT_LOOKS_LIKE_GRAPPLING_HOOK;
      }
      if (second == firewood or logs or rotten_wood or wood)
        "If you're trying to make a raft, then you're out of luck. The rope is too thick and ", (the)second, " ", (IsOrAre)second, " too short. I'm sure you can find a place where the river is shallow enough to wade across.";
    ThrowAt:
      "You hang onto one end of the rope and throw the other end. It has nothing to hook onto, so you gather it up again.";
    Untie:
      if (self hasnt scenery)
        "It's not tied to anything.";
      print "The knot that ties the rope to the top of the mast ";
      if (mast has scenery)
        print_ret (string)IS_OUT_OF_YOUR_REACH;
      else
        "has shrunk over time. You'll never get it untied. If you want to take the rope, you'll have to cut it.";
  ],
has scenery;

!----------------------------------------
! Grappling hook
!----------------------------------------
Object grappling_hook "grappling hook"
with
  name 'grappling' 'hook' 'rope' 'anchor',
  description
  [;
    print "It's a long piece of rope with an anchor tied to the end.";
    if (self has general)
      print " The", (string)ANCHORED_END_HOOKED_OVER_DRAWBRIDGE;
    "";
  ],
  before
  [;
    Drop:
      if (self has general)
        "If you drop the rope now, it'll swing across the moat towards the drawbridge and you'll never be able to recover it.";
    Pull:
      if (self has general)
      {
        give self ~general;
        give drawbridge open;
        "You pull the rope taut, then pull with all your might until the drawbridge comes crashing down. Nice work!";
      }
    ThrowAt:
      if (second == branches)
        print_ret (string)YOU_HANG_ONTO_ROPE_AND_TOSS_IT, "at the overhead branches, but they're too high. The grappling hook comes crashing back to Earth, just missing your head, and lands in the mud with a loud SQUELCH. You quickly draw it in before it sinks in the mud.";
      if (second ~= drawbridge)
        "There's nothing worth throwing it at.";
      if (drawbridge has open)
        "Why would you want to do that? The drawbridge is already lowered.";
      if (self has general)
        "You've already done that and it's caught at the top of the drawbridge.";
      give self general;
      print_ret (string)YOU_HANG_ONTO_ROPE_AND_TOSS_IT, "over the top of the drawbridge on the far side of the moat. Luckily, it catches on the first attempt.";
    Untie:
      if (self has general)
        "You can't untie it while the", (string)ANCHORED_END_HOOKED_OVER_DRAWBRIDGE;
      move anchor to parent(self);
      move rope to parent(self);
      remove self;
      "You untie the rope from the anchor.";
  ],
has;

!========================================
! Room 15: West Riverbank
!========================================
Object room15 "West Riverbank"
with
  description "You're at a place in the river that is shallower than the rest, making it a good place to cross. The river has flooded part of the meadow to the north which has the musty smell of stagnant water. The path along the riverbank goes back to the south.",
  n_to
  [;
    room16.time_left = 0;
    StartDaemon(room16);
    return room16;
  ],
  s_to room13,
  e_to
  [;
    if (fish in self)
      "You take one step into the river where the water is only ankle deep. When you do, the man-eating fish start nibbling on your boots, so you quickly step back out of the water.";
    return room17;
  ],
  before
  [;
    Hint:
      if (fire notin nothing && fire hasnt general)
        print_ret (string)GOOD_PLACE_TO_GET_WATER;
      if (room17 hasnt visited)
      {
        print "This looks like a good spot to cross the river";
        if (fish in self)
          print ", if not for those pesky fish. Man eaters are meat eaters";
        ".";
      }
    Smell:
      "You can smell rotting vegetation to the north.";
    Swim:
      <<Enter river>>;
  ],
has light;

!========================================
! Room 16: Swamp
!========================================
Object room16 "Swamp"
with
  description "You're in a wet swamp that's coated with a thick layer of algae dotted with lily pads. Thick branches shade the area and the croaking of frogs can be heard from dark rotting mud. The only safe route from here is back to the south.",
  s_to
  [;
    StopDaemon(self);
    return room15;
  ],
  before
  [;
    Drop:
      "Don't drop ", (the)noun, " here or ", (ItOrThey)noun, " will sink in the mud.";
    Hint:
      "All that glitters is not gold, especially frogs.";
    Listen:
      "You can hear the croaking of frogs. They seem to be saying, ~This is our territory. Get out of here if you know what's good for you.~";
    Smell:
      "It smells of mud and rotting vegetation. It's really not nice here.";
    Swim:
      "You can't swim in mud.";
  ],
  daemon
  [;
    print "^You're slowly sinking into the mud. ";
    switch (self.time_left++)
    {
      0:"It now covers your ankles.";
      1:"It's halfway up your shins.";
      2:"Bubbles start emerging from the mud and you drop suddenly. It's now nearly up to your waist. You'd better get out of here while you still can before you get consumed in the viscous muck!";
      3:deadflag = 1;
        "There's a sudden GLURP, GLURP, GLURP and you're sucked below the surface of the mud, never to be seen again.";
    }
  ],
  time_left 0,
has light;

!----------------------------------------
! Swamp
!----------------------------------------
Object "swamp" room16
with
  name 'swamp' 'thick' 'wet' 'mud',
  description "There's lots of thick wet mud surrounded by more thick wet mud. And it really stinks!",
has scenery;

