!========================================
! Room 17: East Riverbank
!========================================
Object room17 "East Riverbank"
with
  description "You're on the eastern bank of the River Nudd, where thick rushes grow along the entire length of the river. You can go back across the river at this point, as the narrow crossing is to the west, where you flattened some of the rushes when you emerged from the river. A thin goat path meanders northeast up a slope.",
  w_to room15,
  u_to room18,
  ne_to room18,
  before
  [;
    Hint:
      if (room18 hasnt visited)
        print_ret (string)FOLLOW_PATH;
