!========================================
! Room 18: Thick Vegetation
!========================================
Object room18 "Thick Vegetation"
with
  description "You're in a patch of thick vegetation at the top of a goat path that heads southwest down a hill to the river. The path flattens out towards the east.",
  e_to room19,
  d_to room17,
  sw_to room17,
  before
  [;
    Hint:
      if (garlic in nothing)
        "Examine the vegetation", (string)AND_DO_WHAT_IS_SUGGESTED;
      if (room19 hasnt visited)
        print_ret (string)FOLLOW_PATH;
  ],
has light;

!----------------------------------------
! Thick vegetation
!----------------------------------------
Object "vegetation" room18
with
  article SOME,
  name 'patch' 'of' 'thick' 'vegetation' 'foliage' 'low' 'scrubby-looking' 'scrubby' 'looking' 'scrub' 'bush' 'bushes',
  description
  [;
    print "The vegetation consists of low scrubby-looking bushes for the most part.";
    if (garlic in nothing)
      print " It might be worth searching it.";
    "";
  ],
  before
  [;
    LookUnder, Search:
      print " You scrounge around in the bushes and find ";
      if (garlic notin nothing)
        "absolutely nothing.";
      move garlic to location;
      "some wild garlic.";
  ],
has scenery;

!----------------------------------------
! Wild garlic
!----------------------------------------
Object garlic "wild garlic"
with
  article SOME,
  name 'wild' 'garlic' 'grass-like' 'leaves' 'round' 'bulb',
  description "It's a few grass-like leaves and a round bulb that smells distinctly of garlic.",
  before
  [;
    Eat, Taste:
      move self to limbo;
      "You brush the dirt off, remove the leaves and the outer skin and eat the whole bulb. That was probably a mistake. Now your breath stinks!";
  ],
has edible;

!========================================
! Room 19: Goat Path
!========================================
Object room19 "Goat Path"
with
  description "The path is flatter here. It continues in a rough easterly direction through thick green grass and west to the area with the bushes.",
  e_to room20,
  w_to room18,
  before
  [;
    Hint:
      if (goat hasnt general && grass in nothing)
        "That grass looks good enough to eat.";
      if (room21 hasnt visited)
        print_ret (string)FOLLOW_PATH;
  ],
has light;

!----------------------------------------
! Bulk grass
!----------------------------------------
Object bulk_grass "grass" room19
with
  article SOME,
  parse_name
  [;
    if (TestScope(grass))
      return 0;
    else
      return -1;
  ],
  name 'grass' 'thick' 'green',
  description "The grass is thick and luscious. You can see why the goats would like it here.",
  before
  [;
    Pull, Take:
      if (grass notin nothing)
        print_ret (string)YOUVE_ALREADY_TAKEN_SOME, "How much grass does one woodcutter need?";
      if (children(player) >= MAX_CARRIED)
      {
        PrintMsg(MSG_TAKE_NO_CAPACITY);
        rtrue;
      }
      move grass to player;
      PronounNotice(grass);
      "You pluck a large tuft of grass out of the ground.";
  ],
has scenery;

!----------------------------------------
! Grass
!----------------------------------------
Object grass "grass"
with
  article "a handful of",
  name 'grass' 'tuft' 'handful' 'of' 'thick' 'green',
  description "It's a tuft of thick green grass.",
  before
  [;
    Eat, Taste:
      "You're not a cow or a sheep or a goat. You'd much prefer a good hearty steak.";
  ],
has;

!========================================
! Room 20: Bare Hillside
!========================================
Object room20 "Bare Hillside"
with
  description "You're quite high now. The path is on a bare hillside with exposed rocks and gets steep as it heads up towards the sound of bleating goats to the north. You can also head back in the direction of the river to the west.",
  n_to room21,!See Go action below
  w_to room19,
  u_to room21,!See Go action below
  before
  [;
    Go:
      if (selected_direction == n_to or u_to && goat hasnt general)
      {
        goat.time_left = 0;
        StartDaemon(goat);
      }
    Hint:
      if (room21 hasnt visited)
        print_ret (string)FOLLOW_PATH;
    Listen:
      "The bleating of goats can be heard in the distance.";
  ],
has light;

!----------------------------------------
! Bare hillside
!----------------------------------------
Object "hillside" room20
with
  name 'bare' 'hillside' 'hill' 'side',
  description "The thick vegetation further to the west has given way to exposed rocks.",
has scenery;

!----------------------------------------
! Rocks
!----------------------------------------
Object rocks "rocks" room20
with
  name 'exposed' 'rock' 'rocks',
  description "The rocks are big, whitish grey and warm to the touch from the sunlight.",
  before
  [;
    Pull, Push, Take, Turn:
      "~Leave no stone unturned~, your granny used to say. Now that you've turned them all, she would be proud.";
  ],
has pluralname scenery;

!========================================
! Room 21: Top of Hill
!========================================
Object room21 "Top of Hill"
with
  description "You're at the top of the slope that descends the steep hill to the south. Stunted trees provide a small amount of shadow. Looking through those trees, you can see across the Nudd River valley to the devastation of your village to the west. The ground flattens out towards the east.",
  s_to room20,
  e_to
  [;
    if (goat hasnt general)
      "The goat won't let you pass.";
    else
      return room22;
  ],
  d_to room20,
  before
  [;
    Go:
      if (selected_direction == s_to or d_to)
        StopDaemon(goat);
      if (selected_direction == e_to && goat has general)
        StopDaemon(goat);
    Hint:
      if (goat hasnt general)
        "Goats eat grass.";
      if (room22 hasnt visited)
        print_ret (string)KEEP_GOING;
  ],
has light;

!----------------------------------------
! Top of hill
!----------------------------------------
Object "top of a hill" room21
with
  article THE,
  name 'summit' 'top' 'of' 'hill',
  description "It's called the top because you can't get any higher. It's all downhill from here, er, physically, not figuratively...you hope.",
has scenery;

!----------------------------------------
! Trees
!----------------------------------------
Object "trees" room21
with
  name 'stunted' 'tree' 'trees' 'big' 'bushes',
  description "They're really just very big bushes that have barely got a foothold in the dry soil.",
  before
  [;
    Cut:
      if (CantBeChopped())
        rtrue;
      "These bushes would barely make worthy adversaries for your trusty axe.";
  ],
has pluralname scenery;

!----------------------------------------
! Goat
!----------------------------------------
Object goat "goat" room21
with
  name 'belligerent' 'looking' 'goat',
  description
  [;
    print "It's a belligerent-looking goat that seems to be ";
    if (self hasnt general)
      "protecting its territory. It looks hungry.";
    else
      "ignoring you now that it's got a large tuft of grass to chew on.";
  ],
  life
  [;
    Answer, Ask, Talk, Tell:
      "~Ba-aa-ah.~";
    Attack:
      print (string)GOAT_HEAD_BUTTS_YOU_DOWN_HILL;
      if (self hasnt general)
        StopDaemon(self);
      PlayerTo(room20, 2);
      rtrue;
    Give, Show:
      if (noun == book)
        "The goat puts on its reading glasses, reads the book from cover to cover, then hands it back to you. ~I preferred 'War and Peace'~, he says. (And if you believe that, I have a nice opera house that you might be interested in buying.)";
      if (noun == garlic)
        "The goat sniffs the garlic and looks at you in disgust, as if to say, ~Is that the best you've got to offer?~";
      if (noun == grass)
      {
        move grass to limbo;
        give self general;
        StopDaemon(self);
        "The goat shuffles closer and grabs the grass from you. It's now distracted as it chews on the grass, so you should be able to pass.";
      }
      "They say that a goat will eat anything, but it won't eat ", (a)noun, ".";
  ],
  before
  [;
    Pull, Push, Take, Touch:
      print (string)GOAT_HEAD_BUTTS_YOU_DOWN_HILL;
      if (self hasnt general)
        StopDaemon(self);
      PlayerTo(room20, 2);
      rtrue;
  ],
  daemon
  [;
    print "^The goat ";
    switch (self.time_left++)
    {
      0:"looks at you with indifference.";
      1:"doesn't seem to like you sharing its territory.";
      2:"starts to lower its head, as though it's about to charge.", (string)YOUD_BETTER_GET_OUT_OF_HERE;
      3:print "head-butts you and you roll down the hill...^^";
        StopDaemon(self);
        PlayerTo(room20, 2);
        rtrue;
    }
  ],
  time_left 0,
has animate neuter;

!========================================
! Room 22: Rocky Plateau
!========================================
Object room22 "Rocky Plateau"
with
  description "You're on a rocky plateau high above the River Nudd. A gentle breeze ruffles your hair. The plateau extends to the east and west.",
  e_to room23,
  w_to room21,
  before
  [;
    Hint:
      if (room23 hasnt visited)
        print_ret (string)KEEP_GOING;
  ],
has light;

!----------------------------------------
! Plateau
!----------------------------------------
Object "plateau" room22
with
  name 'rocky' 'plateau',
  description "This would be an ideal spot for sunbathing, if not for the goat. There's something here that looks suspiciously like goat poo.",
has scenery;

!----------------------------------------
! Goat poo
!----------------------------------------
Object "poo" room22
with
  article SOME,
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'goat' or 'poo')
    {
      i++;
      if (nw == 'goat')
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "You take a closer look. Looks like goat poo. You take a whiff. Smells like goat poo. You stick your finger in it. Feels like goat poo. You have a taste. Tastes like goat poo. Whew, it's a good thing you didn't step in it!",
has scenery;

!----------------------------------------
! Valley
!----------------------------------------
Object "valley" room22
with
  name 'valley' 'river' 'nudd',
  description "It's very scenic-looking from up here.",
has scenery;

