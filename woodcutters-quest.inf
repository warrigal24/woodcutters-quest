! Room 23: Eastern End of Plateau
!========================================
Object room23 "Eastern End of Plateau"
with
  description "You're at the eastern end of a plateau where the elevation allows you to see over the treetops of a forest to the east and, beyond that, the walls of the wizard's castle. The sight of the castle fills you with apprehension. If you decide to chicken out, you can return to the west. Otherwise, you can descend a steep slope to the south.",
  s_to room24,
  w_to room22,
  d_to room24,
  before
  [;
    Hint:
      if (room24 hasnt visited)
        print_ret (string)KEEP_GOING;
  ],
has light;

