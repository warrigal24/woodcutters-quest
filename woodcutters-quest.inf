!----------------------------------------
! Castle (floating object)
!----------------------------------------
Object "castle"
with
  name 'castle' 'rugged' 'walls' 'of' 'wizard^s',
  description "It's a very ominous-looking building, but not as big as you had imagined.",
  found_in room23 room27,
has scenery;

!========================================
! Room 24: Clearing
!========================================
Object room24 "Clearing"
with
  description
  [;
    print "You're in a clearing with a steep wall of grass to one side. It looks as though this area was in frequent use a few years ago, as the soil has been worn bare, apart from ";
    if (hole notin self)
      print "a loose area of soil";
    else
      print "the hole";
    " at your feet. You can climb back towards the top of the plateau to the north or enter the huge forest to the east.";
  ],
  n_to room23,
  e_to room26,
  u_to room23,
  d_to
  [;
    if (hole in self)
      return room25;
  ],
  before
  [;
    Dig:
      if (noun == nothing)
        <<Dig soil>>;
    Hint:
      if (hole has absent)
        "Loose soil can be dug if you've got the right tool. This game has two of them.";
      if (room26 hasnt visited)
        print_ret (string)KEEP_GOING;
  ],
has light;

!----------------------------------------
! Clearing
!----------------------------------------
Object "clearing" room24
with
  name 'clearing' 'steep' 'wall' 'of' 'grass',
  description "This area is clear of vegetation, apart from the steep wall of grass to one side.",
has scenery;

!----------------------------------------
! Forest
!----------------------------------------
Object "forest" room24
with
  name 'forest',
  description "There are lots and lots of trees.",
has scenery;

!----------------------------------------
! Soil
!----------------------------------------
Object soil "soil" room24
with
  article SOME,
  name 'soil' 'loose' 'earth' 'dirt',
  description "It's loose and not as solid as you'd expect.",
  before
  [;
    Dig:
      if (hole in location)
        "You've already exposed the mineshaft. There's no point digging any further.";
      if (second == nothing && pottery in player)
      {
        print (string)WITH_SHARP_POTTERY;
        second = pottery;
      }
      if (second == nothing && shovel in player)
      {
        print "(with the shovel)^";
        second = shovel;
      }
      if (second == nothing)
        "You try digging with your hands, but the soil is harder than it looks. You need something that you can use as a digging implement.";
      if (second ~= pottery or shovel)
        "You can't dig anything with ", (the)second, ".";
      give hole ~absent;
      print "You start digging away at the loose soil, when it suddenly collapses under your feet and you find yourself...^^";
      PlayerTo(room25, 2);
      rtrue;
  ],
has scenery;

!----------------------------------------
! Hole (floating object)
!----------------------------------------
Object hole "hole"
with
  name 'hole',
  description
  [;
    print "It's the hole that was formed when you dug the loose soil in the clearing. You can enter it to ";
    if (self in room24)
      print "return to";
    else
      print "get out of.";
    " the mineshaft.";
  ],
  before
  [;
    Enter:
      if (self in room24)
        <<Go FAKE_D_OBJ>>;
      else
        <<Go FAKE_U_OBJ>>;
  ],
  found_in room24 room25,
has absent scenery;

!========================================
! Room 25: Inside Mineshaft
!========================================
Object room25 "Inside Mineshaft"
with
  description "You're in a disused mineshaft. The rough stone walls are wet and cold. It looks as though there was a cave-in, which has blocked the way further into the mine. Strong sunlight pours in from a hole above that you can easily climb out of.",
  u_to room24,
  before
  [;
    Hint:
      if (nugget in nothing)
        "Examine the mining cart.";
      if (nugget hasnt moved)
        "That silver nugget", (string)MIGHT_COME_IN_HANDY;
  ],
has light;

!----------------------------------------
! Mineshaft
!----------------------------------------
Object "mineshaft" room25
with
  name 'mineshaft',
  description "It's been cut into the rock by hand, but it's now caved in. The walls are still damp.",
  before
  [;
    Search:
      "Lots of damp rocks lie around, but nothing useful here, sadly.";
  ],
has scenery;

!----------------------------------------
! Mining cart
!----------------------------------------
Object cart "mining cart" room25
class OpenContainer
with
  name 'mining' 'cart',
  description
  [;
    print "The old mining cart sits rusting in the shadows. ";
    <<Search self>>;
  ],
  before
  [;
    Search:
      if (nugget in nothing)
        move nugget to self;
  ],
has container open static;

!----------------------------------------
! Silver nugget
!----------------------------------------
Object nugget "silver nugget"
with
  name 'small' 'kidney-shaped' 'silver' 'nugget' 'shiny',
  description "It's a small, kidney-shaped silver nugget and unusually shiny, as though someone had cleaned it when they found it.",
has;

!========================================
! Room 26: Pebbly Path
!========================================
Object room26 "Pebbly Path"
with
  description "You're on a pebbly path that leads down into a forest to the east. The tops of tall trees whisper quietly and lank grass tugs at your feet. The path back to the clearing lies to your west.",
  e_to room27,!See Go action below
  w_to room24,
  d_to room27,!See Go action below
  before
  [;
    Go:
      if (selected_direction == e_to or d_to && bear in room27)
      {
        bear.time_left = 0;
        StartDaemon(bear);
      }
    Hint:
      if (room27 hasnt visited)
        print_ret (string)FOLLOW_PATH;
  ],
has light;

!----------------------------------------
! Pebbly path
!----------------------------------------
Object "path" room26
with
  name 'downslope' 'pebbly' 'path',
  description "The pebbles on the path are quite loose and scatter under your feet.",
has scenery;

!----------------------------------------
! Pebbles
!----------------------------------------
Object "pebbles" room26
with
  name 'pebble' 'pebbles',
  before
  [;
    Take:
      "There's no point filling your pockets with pebbles.";
  ],
has pluralname scenery;

!----------------------------------------
! Grass
!----------------------------------------
Object "grass" room26
with
  article SOME,
  name 'grass',
  description "It's tough, green and hardy-looking grass.",
has scenery;

!----------------------------------------
! Forest
!----------------------------------------
Object "forest" room26
with
  name 'forest',
  description "The forest spreads out from the base of the valley and seems to go on forever to the east.",
has scenery;

!========================================
! Room 27: Edge of Forest
!========================================
Object room27 "Edge of Forest"
with
  description "You're at the start of the forest that surrounds the wizard's castle. A path leads into the forest to the east and goes up the slope to the west. If not for the path, the thick trees of the forest would form an impenetrable barrier. There's an unsettling atmosphere of dread ahead.",
  e_to
  [;
    if (bear in self)
      "In case you hadn't noticed, there's a bear blocking the path to the east.";
    else
      return room28;
  ],
  w_to room26,!See Go action below
  u_to room26,!See Go action below
  before
  [;
    Go:
      if (selected_direction == w_to or u_to && bear in self)
        StopDaemon(bear);
    Hint:
      if (bear in self)
        "What do bears eat...besides people?";
      if (room28 hasnt visited)
        print_ret (string)FOLLOW_PATH;
  ],
has light;

!----------------------------------------
! Forest (floating object)
!----------------------------------------
Object "forest"
with
  name 'forest',
  description "The forest forms an impenetrable wall of trees and what should be the sound of birds, insects and other creatures is replaced with an ominous silence.",
  found_in room27 room28 room29,
has scenery;

!----------------------------------------
! Trees (floating object)
!----------------------------------------
Object "trees"
with
  name 'tree' 'trees',
  description "The trees are growing very close together, as though huddling in fright.",
  before
  [;
    Cut:
      if (CantBeChopped())
        rtrue;
      "These trees are too far away to lug all the way back to the village. Leave them for future generations.";
  ],
  found_in room27 room28 room29,
has pluralname scenery;

!----------------------------------------
! Path (floating object)
!----------------------------------------
Object "path"
with
  name 'path' 'leaf' 'litter',
  description "The path is covered in leaf litter and leads from east to west.",
  found_in room27 room28,
has scenery;

!----------------------------------------
! Ferocious-looking bear
!----------------------------------------
Object bear "ferocious-looking bear" room27
with
  name 'ferocious' 'looking' 'bear',
  description "The bear blocks the path through the forest to the east. It looks hungry.",
  life
  [;
    Answer, Ask, Talk, Tell:
      "Bears don't talk.";
    Attack:
      deadflag = 1;
      "That wasn't such a smart idea. Despite your big build, the bear is bigger and stronger than you and tears you to pieces.";
    Give:
      if (noun ~= honeycomb)
        "Is it really worth risking your life by offering gifts to a bear?";
      remove self;
      remove honeycomb;
      StopDaemon(self);
      "The bear grabs the honeycomb from you and wanders off into the forest to enjoy the sweet treat.";
  ],
  daemon
  [;
    print "^The bear ";
    switch (self.time_left++)
    {
      0: "sees you and starts sniffing in your direction.";
      1: "doesn't look very friendly.";
      2: "starts moving towards you.", (string)YOUD_BETTER_GET_OUT_OF_HERE;
      3: deadflag = 1;
        "pounces on you. In just a few minutes, it has torn you to pieces with its sharp claws.";
    }
  ],
  time_left 0,
has animate neuter;

!========================================
! Room 28: Forest Path
!========================================
Object room28 "Forest Path"
with
  description "You're on a forest path, which feels claustrophobic. There are no birds singing and no insects buzzing, though you can see a break in the trees to the east. The path also continues through the forest back to the west.",
  e_to room29,
  w_to room27,
  before
  [;
    Hint:
      if (room29 hasnt visited)
        print_ret (string)FOLLOW_PATH;
  ],
has light;

!========================================
! Room 29: South of Castle Moat
!========================================
Object room29 "South of Castle Moat"
with
  description "You're outside the forest which lies to the west. The wizard's castle stands before you, to the north. The battlements look like a series of broken teeth. There's a moat between you and the castle that looks as though it would be fatal if you tried to enter it. You wonder if the wizard can see you from his tower beyond the castle walls.",
  n_to
  [;
    if (drawbridge hasnt open)
      <<Enter moat>>;
    else
      return room30;
  ],
  w_to room28,
  before
  [;
    Go:
      if (grappling_hook has general)
        "You can't go anywhere while you're hanging onto that grappling hook.";
    Hint:
      if (drawbridge hasnt open)
      {
        if (grappling_hook hasnt general)
        {
          print (string)HAVE_YOU_EXAMINED, "drawbridge? That gap looks promising. ";
          if (rope has scenery || anchor in nothing)
            "The things you need can be found at the boat.";
          if (grappling_hook in nothing)
            "Make use of the things you found at the boat.";
          if (grappling_hook hasnt general)
            "You've made the right tool. Throw it at the drawbridge.";
        }
        "Pull the grappling hook!";
      }
      if (room30 hasnt visited)
        "Cross the drawbridge.";
    Smell:
      print_ret (string)UNPLEASANT_SMELL_COMING_FROM_MOAT;
    Swim:
      <<Enter moat>>;
  ],
has light;

!----------------------------------------
! Castle
!----------------------------------------
Object "castle" room29
with
  name 'wizard^s' 'castle',
  description "It's protected by a high curtain wall. Beyond the wall, you can see the top of a tall tower.",
has scenery;

!----------------------------------------
! Tower (floating object)
!----------------------------------------
Object "tower"
with
  name 'top' 'of' 'tower' 'tall' 'window' 'windows',
  description "You can only see that there's a tall tower with windows. It seems neglected and lifeless, even in the strong sunlight.",
  found_in room29 room30 room31,
has scenery;

!----------------------------------------
! Wall
!----------------------------------------
Object "wall" room29
with
  name 'wall' 'walls' 'high' 'curtain' 'battlements' 'ramparts',
  description "It's derelict and no one seems to be patrolling the battlements.",
  before
  [;
    Climb:
      "You'll have to get across the moat first.";
  ],
has scenery;

!----------------------------------------
! Moat (floating object)
!----------------------------------------
Object moat "moat"
with
  name 'moat' 'soup-like' 'sludge' 'reeds' 'dirty' 'water',
  description
  [;
    print "The moat is a soup-like sludge of reeds and dirty water. It's the very definition of 'deadly looking'. ";
    if (self in room29)
      "I wouldn't enter it if I were you.";
    else
      "It looks even more deadly when looking down on it from atop the drawbridge.";
  ],
  before
  [;
    Climb, Enter:
      "The moat is full of reeds and sludge and dirty water. It really doesn't look like a healthy place to be.";
    Drink:
      "You're kidding, right?";
    JumpOver:
      if (self in room29)
        "It's too far to jump.";
  ],
  found_in room29 room30,
has scenery;

!----------------------------------------
! Drawbridge
!----------------------------------------
Object drawbridge "drawbridge" room29
with
  name 'drawbridge' 'bridge' 'gap',
  short_name
  [;
    if (self hasnt open)
      print "raised ";
    else
      print "lowered ";
    rfalse;
  ],
  description
  [;
    print "The drawbridge is ";
    if (self hasnt open)
      "raised to prevent people like you crossing the moat, although you do notice a gap between the top of the drawbridge and the castle ramparts.";
    else
      "lowered so that you can now cross the moat and enter the castle to the north.";
  ],
  before
  [;
    Enter:
      if (self has open)
        <<Go FAKE_N_OBJ>>;
  ],
has static;

!========================================
! Room 30: On Drawbridge
!========================================
Object room30 "On Drawbridge"
with
  description "You're on the castle drawbridge, which crosses the moat. Looking down makes you feel queasy as the stench of the murky waters rises to your nostrils. The entry to the castle is to the north. If you change your mind, the bank of the moat is to the south.",
  n_to room31,
  s_to room29,
  before
  [;
    Hint:
      if (room31 hasnt visited)
        print_ret (string)KEEP_GOING;
    Smell:
      print_ret (string)UNPLEASANT_SMELL_COMING_FROM_MOAT;
    Swim:
      <<Enter moat>>;
  ],
has light;

!----------------------------------------
! Castle (floating object)
!----------------------------------------
Object "castle"
with
  name 'wizard^s' 'castle',
  description "The castle looks very imposing now that you're up close to it.",
  before
  [;
    Enter:
      if (self in room30)
        <<Go FAKE_N_OBJ>>;
    Exit:
      if (self in room31)
        <<Go FAKE_S_OBJ>>;
  ],
  found_in room30 room31,
has scenery;

!----------------------------------------
! Drawbridge floating object)
!----------------------------------------
Object "drawbridge"
with
  name 'drawbridge' 'bridge' 'thick' 'wood' 'iron' 'reinforcements',
  description "It's a sturdy bridge made from thick wood with iron reinforcements, but it clearly doesn't get used a lot.",
  before
  [;
    Enter:
      if (self in room31)
        <<Go FAKE_S_OBJ>>;
  ],
  found_in room30 room31,
has scenery;

!========================================
! Room 31: Castle Courtyard
!========================================
Object room31 "Castle Courtyard"
with
  description "You're in the castle courtyard. It's a narrow area that leads to an open archway set into a tall tower to the north. The cobbles here are blood splattered and there's a definite smell of corruption. The open drawbridge is to the south.",
  n_to
  [;
    if (guard hasnt general)
      "The goblin guard blocks your path. ~You not wizard. You not enter castle.~";
    return room32;
  ],
  s_to room30,
  before
  [;
    Hint:
      if (guard hasnt general)
      {
        if (nugget notin guard)
        {
          print "Have you tried bribery? ";
          if (hole has absent)
            "You'll need to do some digging around, but not here.";
          if (nugget in nothing)
            "Gold and silver can be found in mines.";
          else
            print_ret (string)GOBLINS_RENOWNED_FOR_LOVE_OF_GOLD_AND_SILVER;
        }
        "There are times when violence is the answer.", (string)THIS_IS_ONE_OF_THEM;
      }
      if (shield hasnt general)
      {
        print "The goblin's shield is pretty dull. Maybe you could shine it up a bit.";
        if (polish hasnt moved)
          print " You'll need something you left back at the village.";
        "";
      }
      if (wizard hasnt general && shield notin player)
        "Make sure to take that shiny new shield with you.";
      if (nugget in location)
        "Don't leave the silver nugget behind.";
      if (gold in nothing)
        print_ret (string)DONT_FORGET_TO, "search the guard before you go.";
      if (gold hasnt moved)
        print_ret (string)DONT_FORGET_TO, "take the gold with you.";
      if (room32 hasnt visited)
        "Time to enter the castle.";
  ],
has light;

!----------------------------------------
! Courtyard
!----------------------------------------
Object "courtyard" room31
with
  name 'courtyard' 'narrow' 'area' 'open' 'archway',
  description "The courtyard is lined by cobblestones and leads to an open archway in the tower.",
has scenery;

!----------------------------------------
! Cobblestones
!----------------------------------------
Object "cobblestones" room31
with
  name 'cobbles' 'cobblestones' 'blood',
  description "The cobblestones are splashed with blood. You're thankful that it's not your blood, but you're also hopeful that it's not from the villagers.",
has pluralname scenery;

!----------------------------------------
! Goblin guard
!----------------------------------------
Object guard "goblin guard" room31
with
  name 'goblin' 'guard' 'body',
  short_name
  [;
    if (self has general)
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "The goblin guard is big, fat and hairy. He's much bigger than you";
    if (self has general)
      ", but he now lies on the ground in a pool of blood. You nudge the body with your toe to make sure he's dead.";
    print " and blocks entry to the castle. ";
    if (shield in self)
      "He holds a shield as if to exert his authority.";
    else
      "He's fondling the silver nugget.";
  ],
  life
  [;
    if (self has general)
      print_ret (string)HES_NOW_DEAD;
    Ask:
      wn = consult_from;
      switch (NextWord())
      {
        'blood':
          "~Blood from last night's dinner. Pork roast. Yum.~";
        'castle':
          "~You blind? This castle. You not go in.~";
        'dungeon':
          "~Dungeon not nice place. Too crowded. Too many villagers.~", (string)VILLAGERS_MUST_STILL_BE_ALIVE;
        'goblin':
          "~Me goblin. You not goblin.~";
        'gold':
          "~You got gold? Goblin like gold. You wanna trade?~";
        'guard':
          "~Me guard. Me guard castle, so you not go in.~";
        'him', 'himself':
          "~Me guard castle. You stay out.~";
        'me', 'myself', 'self':
          "~You not know who you are? Me not know either.~";
        'shield':
          if (shield in self)
            "~Shield mine. You get your own.~";
          else
            "~Shield yours now. We do fair trade.~";
        'silver', 'nugget':
          if (nugget in self)
            "~Silver nugget mine now. We do fair trade.~";
          else
            "~You got silver? Goblin like silver. You wanna trade?~";
        'tower':
          "He looks up at the tower. ~Pretty big, huh? That wizard place. Only wizard go there.~";
        'vampire':
          "~What vampire?~ You explain that it's someone who drinks human blood. ~Not sound like nice person. Glad he not drink goblin blood.~";
        'villager', 'villagers':
          "~Villagers in dungeon, but me not allowed to tell you that.~", (string)VILLAGERS_MUST_STILL_BE_ALIVE;
        'wizard':
          "~Wizard in wizard place, so no one go in.~";
        default:
          "~You ask lot of questions.~";
      }
    Attack:
      if (CantBeAttacked())
        rtrue;
      if (shield in self)
        "The goblin guard might look like a fat slob, but he's quick on his feet and easily deflects your attack with his shield. ~What that for? Now you not enter castle. You not enter castle anyway.~";
      give self general;
      move nugget to location;
      print_ret (string)YOU_TAKE_A_SWING_WITH_YOUR_AXE, " and cleave the defenceless goblin. He drops the nugget and falls to the ground in a pool of blood.^^You feel really bad. You've never killed anyone before and this poor fellow was probably just doing his job, but he was one of the wizard's minions and he was preventing you from getting to the wizard...and possibly the villagers.";
    Give:
      if (noun ~= nugget)
        "~Me not need ", (ThatOrThose)noun, ". Not valuable.~ ", (string)GOBLINS_RENOWNED_FOR_LOVE_OF_GOLD_AND_SILVER, " Do you have something more valuable that you can offer him?";
      move nugget to self;
      move shield to player;
      "~Wizard not allow bribes. Do trade instead.~ He pats his pockets and comes up with nothing. ~Here, take this.~ He gives you his shield in exchange for the silver nugget.";
    Show:
      if (noun ~= nugget)
        "~Me not interested in ", (ThatOrThose)noun, ". Now go away.~";
      else
        "The goblin's eyes light up. ~That silver? You want trade?~";
    Talk:
      "~What you wanna talk about? Maybe you ask about something, me answer. Sound like good deal?~";
  ],
  before
  [;
    Search:
      if (self hasnt general)
        "You can't get close enough to the goblin to search him.";
      print "You search the goblin's body and find ";
      if (gold notin nothing)
        "nothing else.";
      move gold to location;
      "ten gold pieces. Wow! He must have been bluffing when he patted his pockets earlier. The goblin was no fool. He knew that gold was more valuable than silver.";
  ],
has animate transparent;

!----------------------------------------
! Shield
!----------------------------------------
Object shield "shield" guard
with
  name 'shield' 'dull' 'shiny',
  short_name
  [;
    if (self hasnt general)
      print "dull ";
    else
      print "shiny ";
    rfalse;
  ],
  description
  [;
    print "It's a good solid shield";
    if (self hasnt general)
      ", but it's very tarnished.";
    else
      " and it reflects the light off its shiny surface.";
  ],
  before
  [;
    Rub:
      if (self has general)
        "It's already gleaming.";
      if (second == nothing && polish in player)
      {
        print "(with the tub of polish)^";
        second = polish;
      }
      if (second == nothing)
        "You have nothing to polish it with.";
      if (second ~= polish)
        "You can't polish the shield with ", (the)second, ".";
      give self general;
      "You use the tub of polish to shine the shield until it gleams.";
  ],
has;

!----------------------------------------
! Ten gold pieces
!----------------------------------------
Object gold "gold pieces"
with
  article "ten",
  name 'ten' '10' 'gold' 'pieces' 'coins',
  description "It's the ten gold pieces that you found on the goblin guard. This will help to pay for the damage caused by the wizard.",
has;

!========================================
! Room 32: Main Hallway
!========================================
Object room32 "Main Hallway"
with
  description "You're in the main hallway of the wizard's castle. It must have been nicely decorated at some point in the past, but years of neglect has left the walls patchy with mildew and decay. There's a room to the north, dark stone steps leading up to the west and more dank steps going down to the east. You can leave the castle to the south.",
  n_to room33,
  s_to room31,
  e_to room36,
  w_to room34,
  u_to room34,
  d_to room36,
has light;

!----------------------------------------
! Hallway
!----------------------------------------
Object "hallway" room32
with
  name 'main' 'hall' 'hallway',
  description "Though neglected for years, you can tell that it's quite ornate beneath the years of filth.",
  before
  [;
    Search:
      "No hidden objects here.";
  ],
has scenery;

!----------------------------------------
! Walls
!----------------------------------------
Object "walls" room32
with
  name 'wall' 'walls' 'mildew' 'decay' 'filth' 'dirt' 'grime',
  description "The walls could do with a good clean to get rid of the dirt and mildew, but that's not your job, you're a woodcutter.",
has scenery;

!----------------------------------------
! Steps (floating object)
!----------------------------------------
Object "steps"
with
  name 'stone' 'stairs' 'step' 'steps' 'stairway' 'staircase' 'dark' 'dank' 'damp' 'sticky' 'grime',
  description "They're smooth stone steps, coated in years of grime. The dampness in the air has left them quite damp and sticky.",
  before
  [;
    Climb, Enter:
      if (self in room35)
        <<Go FAKE_E_OBJ>>;
      if (self in room37)
        <<Go FAKE_W_OBJ>>;
      "The steps head off in two directions, so you'll have to tell me whether to go up or down, east or west.";
  ],
  found_in room32 room34 room35 room36 room37,
has pluralname scenery;

!========================================
! Room 33: Wizard's Library
!========================================
Object room33 "Wizard's Library"
with
  description "Judging by all the books and scrolls on the shelves, you're in the wizard's library. There are no windows in the room, yet it seems to be lit by a dull blue glow and the air crackles with energy. The only exit is to the south.",
  s_to room32,
  before
  [;
    Hint:
      "Ths place is clearly for wizards only.";
  ],
has light;

!----------------------------------------
! Library
!----------------------------------------
Object "library" room33
with
  name 'wizard^s' 'library',
  description "The walls are lines with shelves.",
  before
  [;
    Search:
      "No hidden items found, not even under all the grime.";
  ],
has scenery;

!----------------------------------------
! Shelves
!----------------------------------------
Object shelves "shelves" room33
class Surface
with
  name 'rows' 'of' 'wooden' 'shelf' 'shelves',
  description
  [;
    print "There are rows and rows of wooden shelves. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun ~= book)
        "The shelves are meant for books and scrolls.";
  ],
has pluralname scenery supporter;

!----------------------------------------
! Books
!----------------------------------------
Object "books" shelves
with
  name 'book' 'books',
  description "You browse through the titles on the spines of the books and see that many of them are in a foreign language. The ones you can read are all about magical creatures, spell casting and wizardry. One book that seems out of place is called 'How to Win Friends and Influence People'.",
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      give candle ~light;
      print_ret (string)WHEN_YOU_TRY_BURNING, (the)self, (string)BREEZE_BLOWS_CANDLE_OUT;
    Read:
      print_ret (string)CANT_READ_FROM_DISTANCE;
    Take:
      "You pick a book at random and it somehow slides back onto the shelf.";
  ],
has pluralname static;

!----------------------------------------
! Scrolls
!----------------------------------------
Object "scrolls" shelves
with
  name 'scroll' 'scrolls',
  description "The scrolls come in various shapes and sizes. One thing they have in common is that they all look extremely old.",
  before
  [;
    Burn:
      if (CantBeBurned())
        rtrue;
      give candle ~light;
      print_ret (string)WHEN_YOU_TRY_BURNING, (the)self, (string)BREEZE_BLOWS_CANDLE_OUT;
    Read:
      print_ret (string)CANT_READ_FROM_DISTANCE;
    Take:
      "You select one of the scrolls and a tingle shoots up your arm. Perhaps these can only be taken by a wizard.";
  ],
has pluralname static;

!========================================
! Room 34: Stone Stairs
!========================================
Object room34 "Stone Stairs"
with
  description "You're on some dark stone stairs leading up and down the tower. It feels chilly and you can hear the distant squeak of bats or rats echoing down the stairs.",
  e_to room32,
  w_to room35,!See Go action below
  u_to room35,!See Go action below
  d_to room32,
  before
  [;
    Go:
      if (selected_direction == w_to or u_to && wizard hasnt general)
      {
        wizard.time_left = 0;
        StartDaemon(wizard);
      }
    Listen:
      "You hear squeaks coming from further up the stairs.";
  ],
has light;

!========================================
! Room 35: Wizard's Inner Sanctum
!========================================
Object room35 "Wizard's Inner Sanctum"
with
  description
  [;
    print "You're in the wizard's inner sanctum. It's quite small with very little furniture. ";
    if (curtains hasnt open)
      print "It's also quite dark, due to the closed curtains covering the window.";
    else
      print "It's now well lit by the sunlight streaming in through the window that was previously hidden behind the curtains.";
    " The only exit is down the stone steps to the east.";
  ],
  e_to room34,!See Go action below
  d_to room34,!See Go action below
  before
  [;
    Go:
      if (selected_direction == e_to or d_to && wizard hasnt general)
        StopDaemon(wizard);
    Hint:
      if (wizard hasnt general && shield notin player)
        "Make sure you have something to shield yourself from the wizard's spells.";
      if (wizard hasnt general && shield hasnt general)
        "The wizard is too powerful for you to kill, so see if you can reflect his spells back on him. (Go back to the courtyard for further hints on this.)";
      if (wizard hasnt general)
        "You have what you need, so be patient. Wait until the wizard casts a spell on you and he'll get his comeuppance.";
      if (key in nothing && curtains hasnt open)
        "Let some light in so that you can see what you're doing.";
      if (key in nothing)
        "Search the wizard!";
      if (key hasnt moved)
        "You'll probably need that key.";
      "Find the villagers.";
  ],
has light;

!----------------------------------------
! Wizard's inner sanctum
!----------------------------------------
Object "inner sanctum" room35
with
  article THE,
  name 'wizard^s' 'inner' 'sanctum',
  description "This is a creepy-looking place.",
has scenery;

!----------------------------------------
! Curtains
!----------------------------------------
Object curtains "curtains" room35
with
  name 'curtain' 'curtains',
  description
  [;
    print "They're old black velvet curtains that look very dusty. They're currently ";
    if (self has open)
      "open to allow the sunlight in through the window.";
    else
      "closed.";
  ],
  before
  [;
    Open:
      if (wizard hasnt general)
        "The wizard steps in front of the curtains. ~The curtains stay shut!~";
  ],
  after
  [;
    Close:
      remove window;
      "When you close the curtains, the room goes dark.";
    Open:
      move window to location;
      "When you open the curtains, the sunlight streams in through the window to brighten up the room. You can now see everything much clearer.";
  ],
has openable pluralname scenery;

!----------------------------------------
! Window
!----------------------------------------
Object window "window"
with
  name 'window' 'ornately-carved' 'woodwork',
  description
  [;
    print "It has some ornately-carved woodwork. The window is currently ";
    if (self has open)
      "open so that you can feel a gentle breeze blowing in from across the valley.";
    else
      "closed.";
  ],
has openable scenery;

!----------------------------------------
! Desk
!----------------------------------------
Object desk "desk" room35
class Surface
with
  name 'desk',
  description
  [;
    print "The desk is made of a deep red wood. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun == chair)
        print_ret (The)noun, " won't fit on the desk.";
  ],
has static supporter;

!----------------------------------------
! Writing utensils
!----------------------------------------
Object "writing utensils" desk
with
  name 'writing' 'utensils' 'quill' 'quills',
  description "They're quills and that sort of thing.",
  before
  [;
    Take:
      "If you want to write your memoirs, perhaps wait until after you've rescued the villagers.";
  ],
has pluralname static;

!----------------------------------------
! Chair
!----------------------------------------
Object "chair" room35
with
  name 'chair' 'high-backed' 'images' 'of' 'bats' 'intricate' 'pattern' 'frame',
  description
  [;
    print "It's a high-backed chair with carved images of bats forming an intricate pattern around the frame. ";
    <<Search self>>;
  ],
  before
  [;
    if (action ~= ##Examine && wizard hasnt general)
      "The wizard stands between you and the chair.";
    Climb, Enter:
      "You have no time to be lazing around. Now that the wizard is dead, you need to find the villagers.";
  ],
has enterable static supporter;

!----------------------------------------
! Wizard
!----------------------------------------
Object wizard "wizard" room35
with
  article
  [;
    if (self hasnt general)
      print "an";
    else
      print "a";
  ],
  name 'evil' 'dead' 'wizard' 'ram-like' 'white' 'eyes' 'ram' 'like' 'horn' 'horns' 'head',
  short_name
  [;
    if (self hasnt general)
      print "evil ";
    else
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "He's white eyed with ram-like horns protruding from his head. ";
    if (self hasnt general)
      "He looks angry at the intrusion into his private domain.";
    else
      "His charred body now lies lifeless on the floor.";
  ],
  life
  [;
    if (self has general)
      print_ret (string)HES_NOW_DEAD;
    Answer, Ask, Talk, Tell:
      "You try, but he ignores you. ~How did you get past my guard? Did he fall asleep again? If he has, I'll turn him into a toad.~";
    Attack:
      if (CantBeAttacked())
        rtrue;
      move axe to location;
      print_ret (string)YOU_TAKE_A_SWING_WITH_YOUR_AXE, ", but it's blocked by an invisible force that causes your hands to tremble and the axe falls to the floor.";
    Give, Show:
      if (noun == garlic)
        "The wizard just laughs. ~Did you think I was a vampire? Ha, ha, ha! That's just a myth.~";
      if (noun == shield && shield has general)
        "You've got the right idea, but don't show it to the wizard or he might tweak to your plan. Just wait for him to cast his spell, then you can use the shield.";
      "~Keep your toys, woodcutter. The only thing I'm interested in is your heart and liver. They will make a lovely pie.~";
  ],
  before
  [;
    Pull, Push, Take, Touch:
      if (self hasnt general)
        print_ret (string)PREFER_TO_KEEP_YOUR_DISTANCE;
      print "You'd prefer to keep your distance";
      if (key in nothing)
        print ", although it wouldn't hurt to search his body";
      ".";
    LookUnder, Search:
      if (self hasnt general)
        print_ret (string)PREFER_TO_KEEP_YOUR_DISTANCE;
      if (curtains hasnt open)
        "There's not enough light to see what you're doing.";
      print "You search the wizard's body and find ";
      if (key notin nothing)
        "nothing else.";
      move key to location;
      "a key.";
  ],
  daemon
  [;
    print "^The wizard ";
    switch (self.time_left++)
    {
      0:"doesn't look happy to see that someone has invaded his inner sanctum.";
      1:"says, ~Who do we have here? Another villager? I must have missed one. Tsk, tsk, tsk. I'm getting careless in my old age.~";
      2:"raises his hand, as though he's about to cast a spell. You'd better be able to defend yourself, otherwise get out of here before he strikes!";
      3:print "casts a spell and a lightning-like bolt shoots out towards you. You instinctively hold ";
        if (shield notin player)
          print "your hand";
        else
          print "the shield";
        print " out to protect yourself";
        if (shield notin player || shield hasnt general)
        {
          deadflag = 1;
          ", but it's no protection against the wizard's spell. You're burned to a crisp and fall lifeless to the ground. Now you'll never know the plight of the villagers.";
        }
        give self general;
        StopDaemon(self);
        " and the wizard's spell is reflected off the shiny surface, straight back at him. The wizard is burned to a crisp and falls lifeless to the ground.";
    }
  ],
  time_left 0,
has animate;

!----------------------------------------
! Key
!----------------------------------------
Object key "key"
with
  name 'key' 'heavy' 'iron',
  description "It's a heavy iron key.",
has;

!========================================
! Room 36: Stone Stairs
!========================================
Object room36 "Stone Stairs"
with
  description "You're on some stone steps leading up and down towards the west and east respectively. You can hear the dripping of water coming from somewhere and there's a wet smell in the air. There's a dim light coming from the hallway above which casts shadows ahead.",
  e_to room37,
  w_to room32,
  u_to room32,
  d_to room37,
  before
  [;
    Listen:
      "You can hear water dripping from somewhere nearby.";
    Smell:
      print_ret (string)MUSTY_SMELL_IN_AIR;
  ],
has light;

!========================================
! Room 37: Entrance to Dungeon
!========================================
Object room37 "Entrance to Dungeon"
with
  description "You're at the entrance to the dungeon. The smell of unwashed bodies and rotten wood clogs your nostrils and your every movement makes an echo. You think you can hear the low murmur of talking beyond the door to the east.",
  w_to room36,
  u_to room36,
  before
  [;
    Hint:
      if (wizard hasnt general)
        "Deal with the wizard first.";
      if (key in nothing)
        "Find the key.";
      if (cell_door has locked)
        "Unlock the door.";
      if (cell_door hasnt open)
        "What are you waiting for? Open the door!";
    Listen:
      print_ret (string)YOU_CAN_HEAR_VOICES;
    Smell:
      print_ret (string)MUSTY_SMELL_IN_AIR;
  ],
has light;

!----------------------------------------
! Entrance to dungeon
!----------------------------------------
Object "entrance to the dungeon" room37
with
  article THE,
  name 'entrance' 'to' 'dungeon',
  description "It's built of solid stone, but with a low ceiling. There's an air of decay about the place.",
has scenery;

!----------------------------------------
! Cell door
!----------------------------------------
Object cell_door "cell door" room37
with
  name 'cell' 'door' 'solid' 'steel',
  description
  [;
    "It's a solid steel door that's currently closed. It seems to lead to a cell, or perhaps deeper into the dungeon. ", (string)YOU_CAN_HEAR_VOICES;
  ],
  before
  [;
    Attack:
      if (CantBeAttacked())
        rtrue;
      print_ret (string)YOUR_AXE_IS_NO_MATCH_FOR_STEEL_DOOR;
    Cut:
      if (CantBeChopped())
        rtrue;
      print_ret (string)YOUR_AXE_IS_NO_MATCH_FOR_STEEL_DOOR;
  ],
  after
  [;
    Open:
      deadflag = 2;
      print "As the door creaks open, you carefully peer inside, not knowing what you will find. As the dim light shines into the cell, you see the dark forms of people huddled together in fear. All of a sudden, there'a shout, ~It's John!~ The huddled figures jump to their feet and rush you. There are hugs and shouts and cries of joy. It's all your friends from the village! You've saved them!^^Congratulations, John. Job well done!^^";
      if (nugget in player)
        print "The silver nugget that you recovered from the guard will help";
      else
        print "It's a pity that you didn't recover the silver nugget from the guard, as this would have helped ";
      print " towards the restoration of the buildings around the village square.^^";
      if (gold in nothing)
        "Unfortunately, you didn't think to search the guard after you killed him, as he had more than he was letting on.";
      print "The gold coins that you found on the guard ";
      if (gold in player)
        print "will help";
      else
        print "would have helped";
      print " with the restoration of the other houses around the village";
      if (gold notin player)
        print ", if only you hadn't left them behind";
      ".";
    Unlock:
      "When you unlock the door, you hear a loud click, followed by whispering voices coming from the other side of the door.";
  ],
  with_key key,
has lockable locked openable static;

!========================================
! Limbo
!========================================
Object limbo;

!========================================
! Printing rules
!========================================
[ consultWord word i;
  for (i=0:i<WordLength(word):i++)
    print (char)LowerCase(WordAddress(word)->i);
];

[ firstConsultWord word i;
  for (i=0:i<WordLength(word):i++)
    if (i == 0)
      print (char)UpperCase(WordAddress(word)->i);
    else
      print (char)LowerCase(WordAddress(word)->i);
];

[ ItOrThey obj;
  if (obj == player)
  {
    print "you";
    rtrue;
  }
  if (obj has pluralname)
  {
    print "they";
    rtrue;
  }
  if (obj has animate)
  {
    if (obj has female)
    {
      print "she";
      rtrue;
    }
    if (obj hasnt neuter)
    {
      print "he";
      rtrue;
    }
  }
  print "it";
];

!========================================
! Other routines
!========================================
[ _UpdateDarkness p_silent _ceil _old_darkness _darkness;
  if (location == thedark)
    _old_darkness = true;
  _ceil = ScopeCeiling(player);
  if (_LookForLightInObj(_ceil, _ceil) == false)
    _darkness = true;
  if (_darkness ~= _old_darkness)
    scope_modified = true;
  if (_darkness)
    location = thedark;
  else
    location = real_location;
  if (_darkness ~= _old_darkness && p_silent == false)
  {
    new_line;
    <Look>;
  }
];

[ CantBeAttacked;
  if (second == nothing && axe in player)
  {
    print "(with the axe)^";
    second = axe;
  }
  if (second == nothing)
    "You have no weapons.";
  if (second ~= axe)
    print_ret (The)second, " ", (IsOrAre)second, " not very effective against ", (a)noun, ".";
  rfalse;
];

[ CantBeBurned;
  if (second == nothing && candle in player && candle has light)
  {
    print "(with the lit candle)^";
    second = candle;
  }
  if (second == nothing)
    "You have nothing to burn ", (the)noun, " with.";
  if (second == embers)
    "Try putting ", (ItOrThem)noun, " in the oven.";
  if (second ~= candle)
    "You can't burn ", (the)noun, " with ", (the)second, ".";
  if (candle hasnt light)
    "The candle isn't lit.";
  if (noun in player)
    "You'll have to drop ", (the)noun, " first, unless you want to set yourself on fire, as well.";
  if (noun has general)
    print_ret (The)noun, " ", (IsOrAre)noun, " too wet to ignite.";
  if (fire in location)
    "There's already a perfectly good fire here. There's no need to start another one.";
  rfalse;
];

[ ImplicitGrabIfNotHeld p_noun;
  p_noun = p_noun;
  rfalse;
];

[ CantBeChopped;
  if (second == nothing && axe in player)
  {
    print "(with the axe)^";
    second = axe;
  }
  if (second == nothing)
    "You have nothing to chop ", (ItOrThem)noun, " with.";
  if (second ~= axe)
    "You can't chop ", (the)noun, " with ", (the)second, ".";
  rfalse;
];

[ LowerCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'A' to 'Z': c = c + 32;
    202, 204, 212, 214, 221: c--;
    217, 218: c = c - 2;
    158 to 160, 167, 168, 208 to 210: c = c - 3;
    186 to 190, 196 to 200: c = c - 5 ;
    175 to 180: c = c - 6;
  }
  return c;
];

[ PlayerDescription;
  print "Your name is John and you're a simple woodcutter. Your occupation keeps you fit and healthy. You have a barrel chest and you've been described as a 'bull of a man', but you take that as a compliment.";
  if (garlic in limbo)
    print " You have really bad breath from eating that wild garlic.";
  "";
];

[ UpperCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'a' to 'z': c = c - 32;
    201, 203, 211, 213, 220: c++;
    215, 216: c = c + 2;
    155 to 157, 164, 165, 205 to 207: c = c + 3;
    181 to 185, 191 to 195: c = c + 5 ;
    169 to 174: c = c + 6;
  }
  return c;
];

!========================================
! Grammar
!========================================
Extend 'ask'
  * 'about' topic -> AskAbout;

Extend 'blow' replace
  * noun -> Blow
  * 'on'/'onto' noun -> Blow
  * 'out' noun -> Extinguish
  * noun 'out' -> Extinguish;

Extend 'climb'
  * 'up' -> Ascend
  * 'up' noun -> Ascend
  * 'down' -> Descend
  * 'down' noun -> Descend
  * 'in'/'into'/'on'/'onto'/'through' noun -> Enter
  * 'off'/'out' noun -> Exit
  * 'off'/'out' 'of' noun -> Exit;

Extend 'cut' first
  * noun 'with' held -> Cut
  * 'up' noun 'with' held -> Cut
  * noun 'up' 'with' held -> Cut;

Extend 'dig'
  * -> Dig;

Extend 'drink' replace
  * noun -> Drink
  * noun 'from' noun -> Drink
  * 'from' noun -> DrinkFrom;

Extend 'empty'
  * noun 'in'/'inside' noun -> EmptyT
  * noun 'from' noun -> Empty reverse;

Extend 'fill' first
  * noun 'with' noun -> FillWith;

Extend only 'fix' replace
  * noun -> Repair;

Extend 'get' first
  * 'down' -> Descend
  * 'up' -> Exit;

Extend 'lock' first
  * noun -> Lock;

Extend 'look'
  * 'into' noun -> Search
  * 'through' noun -> Examine
  * 'behind'/'under' noun -> LookUnder;

Extend only 'put' first
  * noun 'over' noun -> PutOn
  * 'out' noun -> Extinguish
  * noun 'out' -> Extinguish;

Extend 'read' first
  * noun -> Read;

Extend 'rub'
  * noun 'with' noun -> Rub;

Extend only 'say' first
  * topic -> Say;

Extend only 'speak' replace
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Extend 'unlock' first
  * noun -> Unlock;

Verb meta 'about' 'info'
  * -> About;

Verb 'ascend'
  * -> Ascend
  * noun -> Ascend;

Verb meta 'credits'
  * -> Credits;

Verb 'cross'
  * noun -> Enter;

Verb 'dance'
  * -> Dance;

Verb 'descend'
  * -> Descend
  * noun -> Descend;

Verb 'extinguish' 'dampen' 'douse' 'snuff' 'soak' 'unlight' 'wet'
  * noun -> Extinguish;

Verb 'grind' 'sharpen'
  * noun -> Sharpen
  * held 'with' held -> Sharpen;

Verb meta 'help' 'instructions'
  * -> Help;

Verb 'hint' 'clue'
  * -> Hint;

Verb 'inspect' = 'examine';

Verb 'kick' = 'attack';

Verb 'knock' 'bang' 'rap' 'ring' 'tap'
  * 'at'/'on' noun -> Attack
  * noun -> Attack;

Verb 'pour'
  * noun -> Pour
  * 'out' noun -> Pour
  * noun 'out' -> Pour
  * noun 'in'/'into'/'inside'/'on'/'onto'/'over'/'to' noun -> PourT
  * noun 'from' noun -> Pour
  * noun 'out' 'of' noun -> Pour;

Verb 'repair' 'mend' 'replace'
  * noun -> Repair;

Verb 'step'
  * 'in'/'into'/'on'/'onto' noun -> Enter
  * 'off' noun -> Exit;

Verb 'talk' 'babble' 'chat' 'communicate' 'converse' 'gab' 'gossip'
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Verb 'trade' 'exchange'
  * noun 'with' creature -> Give;

Verb 'untie' 'disconnect' 'detach' 'unfasten'
  * noun -> Untie
  * noun 'from' noun -> Untie;

Verb 'use'
  * noun -> Use;

Verb 'xyzzy' 'plover' 'plugh' 'yoho'
  * -> MagicWord;

!========================================
! Actions
!========================================
[ AboutSub;
  print "In 2025, Shaun McClure published a book called 'How to design adventure games'. In the book, he included design notes on a sample game called 'John's Quest'. I thought it might be fun to implement this in PunyInform, so here it is!^^My version of 'John's Quest' is generally true to Shaun's concept, but it does include a lot of enhancements (with Shaun's blessing), so I've renamed it to 'The Woodcutter's Quest'. The enhancements include corrected grammar and capitalisation, reworded location and object descriptions, enhanced vocabulary, extra responses, inclusion of the things that Shaun dismissed as being too hard to implement, and lots of extra puzzles.^^";
  <<Credits>>;
];

[ AscendSub;
  <<Go FAKE_U_OBJ>>;
];

[ AskAboutSub x count npc;
  objectloop (x in location && x has animate && x ~= player)
  {
    count++;
    npc = x;
  }
  if (count == 0)
    "There's no one here to answer your questions.";
  if (count == 1)
    <<Ask npc noun>>;
  "As there are multiple characters here, you'll have to specify who to ask, e.g. ASK MAN ABOUT DOG.";
];

[ CreditsSub;
  "Concept by Shaun McClure.^Game design and coding by Garry Francis.^Play testing by Andrew Apted, Dark Star, Gianluca Girelli, Jade J Aincioa, Melvin Rangasamy and Piergiorgio d'Errico.";
];

[ DanceSub;
  "You trip over your own two feet. When it comes to dancing, you make a good woodcutter.";
];

[ DescendSub;
  <<Go FAKE_D_OBJ>>;
];

[ DrinkSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't drink ", (ThatOrThose)noun, ".";
];

[ DrinkFromSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't drink from ", (ThatOrThose)noun, ".";
];

[ ExtinguishSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't extinguish ", (ThatOrThose)noun, ".";
];

[ FillWithSub;
  "You can't fill ", (the)noun, " with ", (ThatOrThose)second, ".";
];

[ HelpSub;
  "Tell me what to do using simple commands starting with a verb.^^Use LOOK (or L) to refresh the location description. Identify all the objects in the description and EXAMINE (or X) each one. Read responses carefully for hints.^^Use compass directions (N, S, E, W, NE, NW, SE, SW, U and D) to move around. Draw a map as you go.^^Use GET or TAKE to take objects and DROP to drop them again. Use INVENTORY (or I) to see what you're carrying.^^Use AGAIN (or G) to repeat the last command.^^Use UNDO to undo the last command if you make a mistake.^^Use SAVE to save the game and RESTORE to restore it again.^^There are over 100 verbs that you can use, so if something doesn't work, try a different verb or a different way of doing things. Use HINT if you get stuck.^^For full instructions, see the game page at <https://warrigal.itch.io/woodcutters-quest>.";
];

[ HintSub;
  "There's nothing to do here at the moment, but make sure you examine everything you find and draw a map.";
];

[ LockSub k;
  if (ObjectIsUntouchable(noun))
    rtrue;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_LOCK_NOT_A_LOCK, 'lock');
    rtrue;
  }
  if (noun has locked)
  {
    PrintMsg(MSG_LOCK_ALREADY_LOCKED);
    rtrue;
  }
  if (noun has open)
  {
    PrintMsg(MSG_LOCK_CLOSE_FIRST);
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to lock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_LOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun locked;
  run_after_routines_msg = MSG_LOCK_DEFAULT;
  run_after_routines_arg_1 = 'lock';
];

[ LookUnderSub;
  if (location == thedark)
    "But it's dark.";
  "You find nothing of interest.";
];

[ MagicWordSub;
  "You don't dare use any of the ancient magical words for fear of conjuring the wizard or making him aware of your presence.";
];

[ PourSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  if (parent(noun) hasnt container)
    "You can't pour ", (ThatOrThose)noun, ".";
  <<Empty (parent(noun))>>;
];

[ PourTSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  if (parent(noun) hasnt container)
    "You can't pour ", (ThatOrThose)noun, ".";
  if (ObjectIsUntouchable(second))
    rtrue;
  <<EmptyT (parent(noun)) second>>;
];

[ ReadSub;
  if (noun == nothing)
    "I suppose you read tea leaves, too";
  if (ObjectIsUntouchable(noun))
    rtrue;
  "There's nothing legible on ", (ThatOrThose)noun, ".";
];

[ RepairSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  print_ret (CTheyreOrThats)noun, " not broken.";
];

[ SaySub i;
  if (consult_words == 0)
    "You have nothing to say.";
  print "~";
  i = consult_from;
  print (firstConsultWord)i++;
  while (i < consult_from + consult_words)
    print " ", (consultWord)i++;
  print ".~^^";
  wn = consult_from;
  if (consult_words == 1 && NextWord() == 'xyzzy' or 'plover' or 'plugh' or 'yoho')
    <<MagicWord>>;
  if (AfterRoutines())
    rtrue;
  "Nothing happens.";
];

[ SharpenSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't sharpen ", (the)noun, ".";
];

[ TalkSub;
  if (noun == nothing)
    "You start talking to no one in particular.";
  if (noun == player)
    "You start talking to yourself, but it's a one-sided conversation.";
  if (RunLife(noun, ##Talk))
    rtrue;
  print_ret (The)noun, " ", (IsOrAre)noun, " not very talkative.";
];

[ UnlockSub k;
  if (ObjectIsUntouchable(noun))
    rtrue;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_UNLOCK_NOT_A_LOCK, 'unlock');
    rtrue;
  }
  if (noun hasnt locked)
  {
    PrintMsg(MSG_UNLOCK_ALREADY_UNLOCKED, 'unlock');
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to unlock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_UNLOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun ~locked;
  run_after_routines_msg = MSG_UNLOCK_DEFAULT;
  run_after_routines_arg_1 = 'unlock';
];

[ UntieSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't untie ", (ThatOrThose)noun, ".";
];

[ UseSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You'll have to be more explicit than that.";
];

End;
